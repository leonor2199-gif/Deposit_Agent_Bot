<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= method ? '编辑支付配置' : '创建支付配置' %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --bg-main: #f8fafc;
            --panel-bg: rgba(255, 255, 255, 0.8);
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --accent-primary: #2563eb;
            --accent-hover: #1d4ed8;
            --accent-light: #eff6ff;
            --border-color: #e2e8f0;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            --card-radius: 16px;
            --transition-speed: 0.2s;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- Header Navigation Bar --- */
        .app-bar {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            color: white;
            padding: 0.85rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            box-shadow: var(--shadow-md);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .app-bar h1 {
            font-weight: 600;
            font-size: 1.35rem;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .app-bar h1 i {
            color: #fbbf24;
            font-size: 1.45rem;
            filter: drop-shadow(0 2px 4px rgba(251, 191, 36, 0.2));
        }

        .app-bar > div {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        /* --- Global Buttons --- */
        .btn-secondary, .btn-danger {
            padding: 0.5rem 1.1rem;
            border-radius: 12px;
            font-weight: 500;
            font-size: 0.875rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid transparent;
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.1);
            color: #f8fafc;
            border-color: rgba(255, 255, 255, 0.05);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.18);
            border-color: rgba(255, 255, 255, 0.15);
        }

        .btn-danger {
            background: rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            border-color: rgba(239, 68, 68, 0.1);
        }

        .btn-danger:hover {
            background: #ef4444;
            color: white;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
        }

        /* --- Layout Main Elements --- */
        .viewport-container {
            max-width: 800px;
            margin: 2rem auto;
            padding: 0 2.5rem;
            width: 100%;
            flex: 1;
        }

        /* --- Form Container --- */
        .form-container {
            background: white;
            border-radius: var(--card-radius);
            padding: 2.5rem 3rem;
            box-shadow: var(--shadow-sm), var(--shadow-md);
            border: 1px solid var(--border-color);
        }

        .form-container h2 {
            font-weight: 600;
            font-size: 1.5rem;
            color: var(--text-primary);
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .form-container h2 i {
            color: var(--accent-primary);
        }

        /* --- Form Elements --- */
        form label {
            font-weight: 500;
            font-size: 0.875rem;
            color: var(--text-secondary);
            display: block;
            margin: 1.2rem 0 0.4rem 0;
        }

        form label .required {
            color: #ef4444;
            margin-left: 2px;
        }

        form label i {
            margin-right: 6px;
            color: var(--text-muted);
            width: 16px;
            text-align: center;
        }

        form input, form select, form textarea {
            width: 100%;
            padding: 0.6rem 0.9rem;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            font-size: 0.9rem;
            background: #ffffff;
            transition: all var(--transition-speed);
            outline: none;
            color: var(--text-primary);
            font-family: inherit;
        }

        form input:focus, form select:focus, form textarea:focus {
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }

        form input::placeholder, form textarea::placeholder {
            color: var(--text-muted);
        }

        form textarea {
            resize: vertical;
            min-height: 100px;
        }

        /* --- Checkbox Row --- */
        .checkbox-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 1.5rem 0 0.5rem 0;
            padding: 0.75rem 1rem;
            background: #f8fafc;
            border-radius: 10px;
            border: 1px solid var(--border-color);
            transition: all var(--transition-speed);
        }

        .checkbox-row:hover {
            background: #f1f5f9;
        }

        .checkbox-row input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--accent-primary);
            margin: 0;
            flex-shrink: 0;
            cursor: pointer;
        }

        .checkbox-row label {
            margin: 0;
            font-weight: 400;
            font-size: 0.875rem;
            color: var(--text-primary);
            cursor: pointer;
        }

        .form-hint {
            color: var(--text-muted);
            font-size: 0.75rem;
            margin-top: 0.35rem;
            display: block;
        }

        /* --- Actions --- */
        .actions {
            display: flex;
            gap: 12px;
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border-color);
        }

        .btn-primary {
            background: var(--accent-primary);
            color: white;
            padding: 0.65rem 2rem;
            border-radius: 12px;
            font-weight: 500;
            border: none;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none;
        }

        .btn-primary:hover {
            background: var(--accent-hover);
            box-shadow: 0 6px 16px rgba(37, 99, 235, 0.35);
            transform: translateY(-2px);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .btn-secondary-action {
            background: #f1f5f9;
            color: var(--text-secondary);
            padding: 0.65rem 2rem;
            border-radius: 12px;
            font-weight: 500;
            border: none;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all var(--transition-speed);
            text-decoration: none;
        }

        .btn-secondary-action:hover {
            background: #e2e8f0;
            color: var(--text-primary);
        }

        /* --- Scrollbar --- */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* --- Responsive --- */
        @media (max-width: 768px) {
            .app-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
                padding: 1rem 1.5rem;
            }
            .app-bar > div {
                justify-content: flex-start;
                flex-wrap: wrap;
            }
            .viewport-container {
                padding: 0 1rem;
                margin: 1.5rem auto;
            }
            .form-container {
                padding: 1.5rem;
            }
            .form-container h2 {
                font-size: 1.25rem;
            }
            .actions {
                flex-direction: column;
            }
            .actions a, .actions button {
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .app-bar h1 {
                font-size: 1.1rem;
            }
            .app-bar h1 i {
                font-size: 1.2rem;
            }
            .btn-secondary, .btn-danger {
                font-size: 0.75rem;
                padding: 0.4rem 0.8rem;
            }
            .form-container {
                padding: 1.25rem;
            }
            .form-container h2 {
                font-size: 1.1rem;
            }
            .btn-primary, .btn-secondary-action {
                font-size: 0.85rem;
                padding: 0.5rem 1.5rem;
            }
            form input, form select, form textarea {
                font-size: 0.85rem;
                padding: 0.5rem 0.75rem;
            }
        }
    </style>
</head>
<body>
    <header class="app-bar">
        <h1><i class="fas fa-credit-card"></i> <%= method ? '编辑支付配置' : '创建支付配置' %></h1>
        <div>
            <a href="/admin/dashboard" class="btn-secondary"><i class="fas fa-chart-pie"></i> 仪表板</a>
            <a href="/admin/logout" class="btn-danger"><i class="fas fa-sign-out-alt"></i> 退出</a>
        </div>
    </header>

    <main class="viewport-container">
        <div class="form-container">
            <h2><i class="fas fa-cog"></i> <%= method ? '编辑参数集' : '创建新配置' %></h2>
            
            <form method="POST">
                <!-- Bot Selection -->
                <label><i class="fas fa-robot"></i> 选择 Bot <span class="required">*</span></label>
                <select name="botId" required>
                    <option value="">-- 请选择 Bot --</option>
                    <% if(bots && bots.length > 0) { %>
                        <% bots.forEach(bot => { %>
                            <option value="<%= bot._id %>" <%= (method && method.botId && method.botId.toString() === bot._id.toString()) ? 'selected' : '' %>>
                                <%= bot.name %> - <%= bot.plan.toUpperCase() %> (<%= bot.maxPaymentMethods === Infinity ? '∞' : bot.maxPaymentMethods - bot.currentPaymentMethods %> 剩余)
                            </option>
                        <% }) %>
                    <% } %>
                </select>
                <span class="form-hint">此支付方式将分配给选中的 Bot</span>

                <!-- 接口显示名称 -->
                <label><i class="fas fa-tag"></i> 接口显示名称 <span class="required">*</span></label>
                <input type="text" name="name" value="<%= method ? method.name : '' %>" placeholder="例如: 银联快捷支付" required>

                <!-- 分类类型 -->
                <label><i class="fas fa-layer-group"></i> 分类类型 <span class="required">*</span></label>
                <select name="type" required>
                    <option value="bank" <%= method && method.type === 'bank' ? 'selected' : '' %>>银行转账</option>
                    <option value="wallet" <%= method && method.type === 'wallet' ? 'selected' : '' %>>数字钱包</option>
                    <option value="cash" <%= method && method.type === 'cash' ? 'selected' : '' %>>现金存款网络</option>
                    <option value="card" <%= method && method.type === 'card' ? 'selected' : '' %>>直接刷卡输入</option>
                </select>

                <!-- 法人实体名称/账户持有人 -->
                <label><i class="fas fa-building"></i> 法人实体名称 / 账户持有人 <span class="required">*</span></label>
                <input type="text" name="accountName" value="<%= method ? method.accountName : '' %>" placeholder="例如: 上海星瀚科技" required>

                <!-- 账户/系统参考编号 -->
                <label><i class="fas fa-hashtag"></i> 账户 / 系统参考编号 <span class="required">*</span></label>
                <input type="text" name="accountNumber" value="<%= method ? method.accountNumber : '' %>" placeholder="例如: 6217850012345678" required>

                <!-- 银行间CLABE编码（可选） -->
                <label><i class="fas fa-code"></i> 银行间 CLABE 编码（可选）</label>
                <input type="text" name="clabe" value="<%= method ? method.clabe : '' %>" placeholder="例如: CLABE-2024-001">

                <!-- 发卡机构银行名称 -->
                <label><i class="fas fa-university"></i> 发卡机构银行名称 <span class="required">*</span></label>
                <input type="text" name="bankName" value="<%= method ? method.bankName : '' %>" placeholder="例如: 中国银行" required>

                <!-- 静态二维码图片链接（可选） -->
                <label><i class="fas fa-qrcode"></i> 静态二维码图片链接（可选）</label>
                <input type="url" name="qrCode" value="<%= method ? method.qrCode : '' %>" placeholder="https://example.com/qr.png">

                <!-- 终端用户交易路由说明 -->
                <label><i class="fas fa-file-alt"></i> 终端用户交易路由说明 <span class="required">*</span></label>
                <textarea name="instructions" rows="4" placeholder="请使用银联APP或银行柜台转账，备注填写订单号后四位。" required><%= method ? method.instructions : '' %></textarea>

                <!-- 状态 -->
                <div class="checkbox-row">
                    <input type="checkbox" name="isActive" id="isActive" <%= !method || method.isActive ? 'checked' : '' %>>
                    <label for="isActive">立即在 Telegram 界面上传播路由实时状态</label>
                </div>

                <!-- 按钮 -->
                <div class="actions">
                    <button type="submit" class="btn-primary"><i class="fas fa-save"></i> 应用架构更改</button>
                    <a href="/admin/dashboard" class="btn-secondary-action"><i class="fas fa-times"></i> 放弃更改</a>
                </div>
            </form>
        </div>
    </main>

    <script>
        // Bot selection validation
        document.querySelector('form').addEventListener('submit', function(e) {
            const botSelect = this.querySelector('select[name="botId"]');
            if (!botSelect.value) {
                e.preventDefault();
                alert('请先选择一个 Bot');
                botSelect.focus();
                return;
            }
        });

        // QR code validation
        document.querySelector('input[name="qrCode"]')?.addEventListener('change', function() {
            if (this.value && this.value.trim() !== '') {
                try {
                    new URL(this.value.trim());
                    this.style.borderColor = '#22c55e';
                } catch(e) {
                    this.style.borderColor = '#ef4444';
                }
            } else {
                this.style.borderColor = '#d1d9e6';
            }
        });
    </script>
</body>
</html>
