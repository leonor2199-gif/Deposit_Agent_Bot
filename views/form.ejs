<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= method ? '编辑支付配置' : '创建支付配置' %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: #f4f7fc;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .app-bar {
            background: rgba(18, 28, 46, 0.88);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            color: white;
            padding: 0.9rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            box-shadow: 0 8px 24px rgba(0, 20, 40, 0.15);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .app-bar h1 {
            font-weight: 600;
            font-size: 1.5rem;
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .app-bar h1 i {
            color: #60a5fa;
        }

        .app-bar > div {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-secondary, .btn-danger {
            padding: 0.4rem 1.2rem;
            border-radius: 60px;
            font-weight: 500;
            font-size: 0.85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
            border: 1px solid transparent;
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.08);
            color: #e8edf9;
            border-color: rgba(255, 255, 255, 0.08);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.18);
            transform: translateY(-1px);
        }

        .btn-danger {
            background: rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            border-color: rgba(239, 68, 68, 0.2);
        }

        .btn-danger:hover {
            background: rgba(239, 68, 68, 0.3);
            color: #fff;
        }

        .viewport-container {
            max-width: 800px;
            margin: 2rem auto;
            padding: 0 2rem;
            width: 100%;
            flex: 1;
        }

        .form-container {
            background: white;
            border-radius: 28px;
            padding: 2.5rem 3rem;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.04), 0 4px 12px rgba(0, 20, 40, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.6);
        }

        .form-container h2 {
            font-weight: 600;
            font-size: 1.8rem;
            color: #0b1a33;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .form-container h2 i {
            color: #1e3a6b;
        }

        form label {
            font-weight: 500;
            font-size: 0.9rem;
            color: #1f2a44;
            display: block;
            margin: 1.2rem 0 0.4rem 0;
        }

        form label .required {
            color: #ef4444;
            margin-left: 2px;
        }

        form input, form select, form textarea {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid #d1d9e6;
            border-radius: 16px;
            font-size: 0.95rem;
            background: white;
            transition: 0.2s;
            outline: none;
            font-family: inherit;
        }

        form input:focus, form select:focus, form textarea:focus {
            border-color: #1e3a6b;
            box-shadow: 0 0 0 4px rgba(30, 58, 107, 0.08);
        }

        form textarea {
            resize: vertical;
            min-height: 100px;
        }

        .checkbox-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 1.5rem 0 0.5rem 0;
            padding: 0.75rem 1rem;
            background: #f8fafd;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
        }

        .checkbox-row input[type="checkbox"] {
            width: 20px;
            height: 20px;
            accent-color: #1e3a6b;
            margin: 0;
            flex-shrink: 0;
        }

        .checkbox-row label {
            margin: 0;
            font-weight: 400;
            font-size: 0.9rem;
            color: #1f2a44;
            cursor: pointer;
        }

        .form-hint {
            color: #64748b;
            font-size: 0.75rem;
            margin-top: 0.25rem;
            display: block;
        }

        .actions {
            display: flex;
            gap: 12px;
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid #eef2f6;
        }

        .btn-primary {
            background: #1e3a6b;
            color: white;
            padding: 0.7rem 2rem;
            border-radius: 60px;
            font-weight: 600;
            border: none;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            box-shadow: 0 6px 14px rgba(26, 67, 113, 0.25);
            transition: all 0.2s;
            border: 1px solid rgba(255, 255, 255, 0.1);
            text-decoration: none;
        }

        .btn-primary:hover {
            background: #14315a;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(18, 52, 97, 0.3);
        }

        .btn-secondary-action {
            background: #eef2f6;
            color: #1f2a44;
            padding: 0.7rem 2rem;
            border-radius: 60px;
            font-weight: 500;
            border: none;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: 0.15s;
            text-decoration: none;
        }

        .btn-secondary-action:hover {
            background: #dce2ec;
        }

        @media (max-width: 650px) {
            .app-bar {
                flex-direction: column;
                align-items: stretch;
                padding: 0.8rem 1.2rem;
            }
            .app-bar > div {
                justify-content: flex-start;
            }
            .viewport-container {
                padding: 0 1rem;
                margin: 1rem auto;
            }
            .form-container {
                padding: 1.5rem;
            }
            .actions {
                flex-direction: column;
            }
            .actions a, .actions button {
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <header class="app-bar">
        <h1><i class="fas fa-credit-card"></i> <%= method ? '编辑支付配置' : '创建支付配置' %></h1>
        <div>
            <a href="/admin/dashboard" class="btn-secondary"><i class="fas fa-chart-pie"></i> 返回仪表板</a>
            <a href="/admin/logout" class="btn-danger"><i class="fas fa-sign-out-alt"></i> 退出登录</a>
        </div>
    </header>

    <main class="viewport-container">
        <div class="form-container">
            <h2><i class="fas fa-cog"></i> <%= method ? '编辑参数集' : '创建新配置' %></h2>
            
            <form method="POST">
                <!-- Bot Selection -->
                <label>选择 Bot <span class="required">*</span></label>
                <select name="botId" required>
                    <option value="">-- 请选择 Bot --</option>
                    <% if(bots && bots.length > 0) { %>
                        <% bots.forEach(bot => { %>
                            <option value="<%= bot._id %>" <%= (method && method.botId && method.botId.toString() === bot._id.toString()) ? 'selected' : '' %>>
                                <%= bot.name %> - <%= bot.plan.toUpperCase() %> (<%= bot.maxPaymentMethods === Infinity ? '∞' : bot.maxPaymentMethods - bot.currentPaymentMethods %> 剩余)
                            </option>
                        <% }) %>
                    <% } %>
                </select>
                <span class="form-hint">此支付方式将分配给选中的 Bot</span>

                <!-- 接口显示名称 -->
                <label>接口显示名称 <span class="required">*</span></label>
                <input type="text" name="name" value="<%= method ? method.name : '' %>" placeholder="例如: 银联快捷支付" required>

                <!-- 分类类型 -->
                <label>分类类型 <span class="required">*</span></label>
                <select name="type" required>
                    <option value="bank" <%= method && method.type === 'bank' ? 'selected' : '' %>>银行转账</option>
                    <option value="wallet" <%= method && method.type === 'wallet' ? 'selected' : '' %>>数字钱包</option>
                    <option value="cash" <%= method && method.type === 'cash' ? 'selected' : '' %>>现金存款网络</option>
                    <option value="card" <%= method && method.type === 'card' ? 'selected' : '' %>>直接刷卡输入</option>
                </select>

                <!-- 法人实体名称/账户持有人 -->
                <label>法人实体名称 / 账户持有人 <span class="required">*</span></label>
                <input type="text" name="accountName" value="<%= method ? method.accountName : '' %>" placeholder="例如: 上海星瀚科技" required>

                <!-- 账户/系统参考编号 -->
                <label>账户 / 系统参考编号 <span class="required">*</span></label>
                <input type="text" name="accountNumber" value="<%= method ? method.accountNumber : '' %>" placeholder="例如: 6217850012345678" required>

                <!-- 银行间CLABE编码（可选） -->
                <label>银行间 CLABE 编码（可选）</label>
                <input type="text" name="clabe" value="<%= method ? method.clabe : '' %>" placeholder="例如: CLABE-2024-001">

                <!-- 发卡机构银行名称 -->
                <label>发卡机构银行名称 <span class="required">*</span></label>
                <input type="text" name="bankName" value="<%= method ? method.bankName : '' %>" placeholder="例如: 中国银行" required>

                <!-- 静态二维码图片链接（可选） -->
                <label>静态二维码图片链接（可选）</label>
                <input type="url" name="qrCode" value="<%= method ? method.qrCode : '' %>" placeholder="https://example.com/qr.png">

                <!-- 终端用户交易路由说明 -->
                <label>终端用户交易路由说明 <span class="required">*</span></label>
                <textarea name="instructions" rows="4" placeholder="请使用银联APP或银行柜台转账，备注填写订单号后四位。" required><%= method ? method.instructions : '' %></textarea>

                <!-- 状态 -->
                <div class="checkbox-row">
                    <input type="checkbox" name="isActive" id="isActive" <%= !method || method.isActive ? 'checked' : '' %>>
                    <label for="isActive">立即在 Telegram 界面上传播路由实时状态</label>
                </div>

                <!-- 按钮 -->
                <div class="actions">
                    <button type="submit" class="btn-primary"><i class="fas fa-save"></i> 应用架构更改</button>
                    <a href="/admin/dashboard" class="btn-secondary-action"><i class="fas fa-times"></i> 放弃更改</a>
                </div>
            </form>
        </div>
    </main>

    <script>
        // Bot selection validation
        document.querySelector('form').addEventListener('submit', function(e) {
            const botSelect = this.querySelector('select[name="botId"]');
            if (!botSelect.value) {
                e.preventDefault();
                alert('请先选择一个 Bot');
                botSelect.focus();
                return;
            }
        });

        // QR code validation
        document.querySelector('input[name="qrCode"]')?.addEventListener('change', function() {
            if (this.value && this.value.trim() !== '') {
                try {
                    new URL(this.value.trim());
                    this.style.borderColor = '#22c55e';
                } catch(e) {
                    this.style.borderColor = '#ef4444';
                }
            } else {
                this.style.borderColor = '#d1d9e6';
            }
        });
    </script>
</body>
</html>