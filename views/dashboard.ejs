<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>控制中心 · 支付基础设施</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --bg-main: #f8fafc;
            --panel-bg: rgba(255, 255, 255, 0.8);
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --accent-primary: #2563eb;
            --accent-hover: #1d4ed8;
            --accent-light: #eff6ff;
            --border-color: #e2e8f0;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            
            --status-active-bg: #f0fdf4;
            --status-active-text: #166534;
            --status-active-dot: #22c55e;
            
            --status-inactive-bg: #fef2f2;
            --status-inactive-text: #991b1b;
            --status-inactive-dot: #ef4444;
            
            --card-radius: 16px;
            --transition-speed: 0.2s;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- Header Navigation Bar --- */
        .app-bar {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            color: white;
            padding: 0.85rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            box-shadow: var(--shadow-md);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .app-bar h1 {
            font-weight: 600;
            font-size: 1.35rem;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .app-bar h1 i {
            color: #fbbf24;
            font-size: 1.45rem;
            filter: drop-shadow(0 2px 4px rgba(251, 191, 36, 0.2));
        }

        .app-bar > div {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        /* --- User Badge --- */
        .user-badge {
            background: rgba(255, 255, 255, 0.08);
            padding: 0.3rem 1.2rem;
            border-radius: 12px;
            font-size: 0.85rem;
            font-weight: 500;
            border: 1px solid rgba(255, 255, 255, 0.06);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .user-badge i {
            color: #93bbfc;
        }

        .plan-badge {
            padding: 0.2rem 0.8rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 600;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .plan-badge.demo { background: rgba(96, 165, 250, 0.2); color: #60a5fa; border-color: rgba(96, 165, 250, 0.3); }
        .plan-badge.starter { background: rgba(52, 211, 153, 0.2); color: #34d399; border-color: rgba(52, 211, 153, 0.3); }
        .plan-badge.pro { background: rgba(251, 191, 36, 0.2); color: #fbbf24; border-color: rgba(251, 191, 36, 0.3); }
        .plan-badge.enterprise { background: rgba(139, 92, 246, 0.2); color: #a78bfa; border-color: rgba(139, 92, 246, 0.3); }
        .plan-badge.superadmin { background: rgba(244, 63, 94, 0.2); color: #fb7185; border-color: rgba(244, 63, 94, 0.3); }

        /* --- Global Buttons --- */
        .btn-action, .btn-danger, .btn-primary-sm {
            padding: 0.5rem 1.1rem;
            border-radius: 12px;
            font-weight: 500;
            font-size: 0.875rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid transparent;
        }

        .btn-action {
            background: rgba(255, 255, 255, 0.1);
            color: #f8fafc;
            border-color: rgba(255, 255, 255, 0.05);
        }

        .btn-action:hover {
            background: rgba(255, 255, 255, 0.18);
            border-color: rgba(255, 255, 255, 0.15);
            color: white;
        }

        .btn-danger {
            background: rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            border-color: rgba(239, 68, 68, 0.1);
        }

        .btn-danger:hover {
            background: #ef4444;
            color: white;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.25);
        }

        .btn-primary-sm {
            background: var(--accent-primary);
            color: white;
            border: none;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
            cursor: pointer;
        }

        .btn-primary-sm:hover {
            background: var(--accent-hover);
            box-shadow: 0 6px 16px rgba(37, 99, 235, 0.35);
            transform: translateY(-1px);
            color: white;
        }

        .btn-disabled {
            opacity: 0.4;
            cursor: not-allowed;
            pointer-events: none;
        }

        .btn-primary-sm.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
            transform: none !important;
        }

        /* --- Layout Main Elements --- */
        .viewport-container {
            max-width: 1440px;
            margin: 2rem auto;
            padding: 0 2.5rem;
            width: 100%;
            flex: 1;
        }

        /* --- Stats Grid --- */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: white;
            padding: 1.2rem 1.5rem;
            border-radius: var(--card-radius);
            box-shadow: var(--shadow-sm), var(--shadow-md);
            border: 1px solid var(--border-color);
            text-align: center;
            transition: all var(--transition-speed);
        }

        .stat-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        .stat-card h3 {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--text-secondary);
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .stat-card h3 i {
            color: var(--accent-primary);
        }

        .stat-number {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-primary);
            margin-top: 0.2rem;
        }

        .stat-number.limit-reached {
            color: #ef4444;
        }

        .stat-number .limit-label {
            font-size: 0.7rem;
            font-weight: 400;
            color: var(--text-muted);
        }

        /* --- Limit Warning --- */
        .limit-warning {
            background: #fffbeb;
            border: 1px solid #f59e0b;
            color: #92400e;
            padding: 0.8rem 1.5rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .limit-warning i {
            color: #f59e0b;
            font-size: 1.2rem;
        }

        .limit-warning .btn-upgrade {
            margin-left: auto;
            background: #f59e0b;
            color: white;
            padding: 0.4rem 1.2rem;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.8rem;
            transition: all var(--transition-speed);
        }

        .limit-warning .btn-upgrade:hover {
            background: #d97706;
            transform: translateY(-1px);
        }

        /* --- Section Title --- */
        .section-title {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            margin: 2rem 0 1.2rem 0;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .section-title h2 {
            font-weight: 600;
            font-size: 1.25rem;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title h2 i {
            color: var(--accent-primary);
        }

        /* --- Modern Data Table Rendering --- */
        .table-wrapper {
            background: white;
            border-radius: var(--card-radius);
            box-shadow: var(--shadow-sm), var(--shadow-md);
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        .table-scroll {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
            min-width: 720px;
            text-align: left;
        }

        th {
            padding: 1rem 1.5rem;
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.775rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            background: #f8fafc;
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        td {
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            color: var(--text-primary);
            background: white;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: #f8fafc;
        }

        td strong {
            font-weight: 600;
            color: var(--text-primary);
        }

        code {
            background: #f1f5f9;
            padding: 0.15rem 0.6rem;
            border-radius: 6px;
            font-size: 0.8rem;
            color: #1e293b;
            font-family: 'Menlo', 'Monaco', monospace;
        }

        /* --- Decorative Badges & Indicators --- */
        .badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            background: #f1f5f9;
            color: #334155;
            border: 1px solid #e2e8f0;
        }

        .badge-type {
            background: #eff6ff;
            color: #1e40af;
            border: 1px solid #bfdbfe;
        }

        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.2rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .status-indicator::before {
            content: "";
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }

        .status-indicator.active {
            background: var(--status-active-bg);
            color: var(--status-active-text);
        }

        .status-indicator.active::before {
            background: var(--status-active-dot);
        }

        .status-indicator.inactive {
            background: var(--status-inactive-bg);
            color: var(--status-inactive-text);
        }

        .status-indicator.inactive::before {
            background: var(--status-inactive-dot);
        }

        /* --- Row Inline Actions Buttons --- */
        .btn-edit, .btn-delete {
            border: none;
            background: transparent;
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.35rem 0.75rem;
            border-radius: 8px;
            transition: all 0.15s ease;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            text-decoration: none;
        }

        .btn-edit {
            color: var(--accent-primary);
            background: var(--accent-light);
        }

        .btn-edit:hover {
            background: #dbeafe;
            color: var(--accent-hover);
        }

        .btn-delete {
            color: #dc2626;
            background: #fef2f2;
        }

        .btn-delete:hover {
            background: #fee2e2;
            color: #991b1b;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem !important;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 2.5rem;
            display: block;
            margin-bottom: 1rem;
            color: var(--border-color);
        }

        .empty-state a {
            color: var(--accent-primary);
            text-decoration: none;
            font-weight: 500;
        }

        .empty-state a:hover {
            text-decoration: underline;
        }

        /* --- Scrollbar Performance Modernization --- */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        /* --- Responsive Adaptive Controls --- */
        @media (max-width: 768px) {
            .app-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
                padding: 1rem 1.5rem;
            }
            .app-bar > div {
                justify-content: flex-start;
                flex-wrap: wrap;
            }
            .viewport-container {
                padding: 0 1rem;
                margin: 1.5rem auto;
            }
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.8rem;
            }
            .stat-card {
                padding: 0.8rem 1rem;
            }
            .stat-number {
                font-size: 1.4rem;
            }
            .limit-warning {
                flex-direction: column;
                text-align: center;
            }
            .limit-warning .btn-upgrade {
                margin-left: 0;
            }
            .section-title {
                flex-direction: column;
                align-items: flex-start;
            }
            th, td {
                padding: 0.85rem 1rem;
                font-size: 0.8rem;
            }
        }

        @media (max-width: 480px) {
            .app-bar h1 {
                font-size: 1.1rem;
            }
            .app-bar h1 i {
                font-size: 1.2rem;
            }
            .btn-action, .btn-danger, .btn-primary-sm {
                font-size: 0.75rem;
                padding: 0.4rem 0.8rem;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
            .stat-card h3 {
                font-size: 0.65rem;
            }
            .stat-number {
                font-size: 1.2rem;
            }
            .user-badge {
                font-size: 0.75rem;
                padding: 0.25rem 0.8rem;
            }
            th, td {
                padding: 0.6rem 0.75rem;
                font-size: 0.75rem;
            }
        }
    </style>
</head>
<body>
    <header class="app-bar">
        <h1><i class="fas fa-credit-card"></i> 支付基础设施</h1>
        <div>
            <span class="user-badge">
                <i class="fas fa-user-circle"></i> 
                <%- typeof admin !== 'undefined' && admin ? admin.username : 'Guest' %>
                <span class="plan-badge <%- typeof admin !== 'undefined' && admin && admin.plan ? admin.plan : 'demo' %>">
                    <i class="fas fa-crown"></i> 
                    <%- typeof adminPlan !== 'undefined' && adminPlan && adminPlan.displayName ? adminPlan.displayName : (typeof admin !== 'undefined' && admin && admin.plan ? admin.plan.toUpperCase() : 'DEMO') %>
                </span>
            </span>
            
            <!-- Menu Items -->
            <% if(typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                <a href="/admin/admins" class="btn-action"><i class="fas fa-user-shield"></i> 管理管理员</a>
                <a href="/admin/groups" class="btn-action"><i class="fas fa-layer-group"></i> 管理群组</a>
                <a href="/admin/plans" class="btn-action"><i class="fas fa-crown"></i> 管理方案</a>
            <% } %>
            <a href="/admin/bots" class="btn-action"><i class="fas fa-robot"></i> 管理 Bots</a>
            <% if(typeof canAdd !== 'undefined' && canAdd && canAdd.paymentMethod !== false) { %>
                <a href="/admin/methods/new" class="btn-action" style="background:rgba(96,165,250,0.15); color:#93bbfc;">
                    <i class="fas fa-plus-circle"></i> 新建配置
                </a>
            <% } else { %>
                <a href="#" class="btn-action btn-disabled" style="background:rgba(96,165,250,0.05); color:#64748b; cursor:not-allowed; pointer-events:none;">
                    <i class="fas fa-plus-circle"></i> 新建配置
                </a>
            <% } %>
            
            <a href="/admin/logout" class="btn-danger"><i class="fas fa-sign-out-alt"></i> 退出</a>
        </div>
    </header>

    <main class="viewport-container">
        <!-- Plan Limit Warnings -->
        <% if(typeof admin !== 'undefined' && admin && admin.plan === 'demo') { %>
            <div class="limit-warning">
                <i class="fas fa-info-circle"></i>
                <span>
                    <strong>Demo 模式</strong> - 您有 <strong><%= typeof stats !== 'undefined' ? stats.messagesToday || 0 : 0 %>/<%= typeof stats !== 'undefined' ? stats.messagesLimit || 20 : 20 %></strong> 条消息今日剩余。
                    <%= (typeof isLimitReached !== 'undefined' && isLimitReached.messages) ? '⚠️ 今日消息已用完！' : '' %>
                </span>
                <a href="/admin/plans" class="btn-upgrade">升级方案</a>
            </div>
        <% } %>

        <% if(typeof isLimitReached !== 'undefined' && isLimitReached.bots) { %>
            <div class="limit-warning">
                <i class="fas fa-exclamation-triangle"></i>
                <span><strong>Bot 数量已达上限</strong> - 当前方案允许 <%= typeof currentAdmin !== 'undefined' ? currentAdmin.maxBots : 0 %> 个 Bot</span>
                <a href="/admin/plans" class="btn-upgrade">升级方案</a>
            </div>
        <% } %>

        <% if(typeof isLimitReached !== 'undefined' && isLimitReached.paymentMethods) { %>
            <div class="limit-warning">
                <i class="fas fa-exclamation-triangle"></i>
                <span><strong>支付方式已达上限</strong> - 当前方案允许 <%= typeof currentAdmin !== 'undefined' ? currentAdmin.maxPaymentMethods : 0 %> 个支付方式</span>
                <a href="/admin/plans" class="btn-upgrade">升级方案</a>
            </div>
        <% } %>

        <!-- Stats Dashboard -->
        <div class="stats-grid">
            <div class="stat-card">
                <h3><i class="fas fa-robot"></i> Bot</h3>
                <div class="stat-number <%= (typeof isLimitReached !== 'undefined' && isLimitReached.bots) ? 'limit-reached' : '' %>">
                    <%= typeof stats !== 'undefined' ? stats.totalBots || 0 : 0 %>/<%= typeof currentAdmin !== 'undefined' ? (currentAdmin.maxBots === Infinity ? '∞' : currentAdmin.maxBots) : 0 %>
                    <span class="limit-label">已用/上限</span>
                </div>
            </div>
            <div class="stat-card">
                <h3><i class="fas fa-credit-card"></i> 支付方式</h3>
                <div class="stat-number <%= (typeof isLimitReached !== 'undefined' && isLimitReached.paymentMethods) ? 'limit-reached' : '' %>">
                    <%= typeof stats !== 'undefined' ? stats.totalMethods || 0 : 0 %>/<%= typeof currentAdmin !== 'undefined' ? (currentAdmin.maxPaymentMethods === Infinity ? '∞' : currentAdmin.maxPaymentMethods) : 0 %>
                    <span class="limit-label">已用/上限</span>
                </div>
            </div>
            <div class="stat-card">
                <h3><i class="fas fa-layer-group"></i> 群组</h3>
                <div class="stat-number <%= (typeof isLimitReached !== 'undefined' && isLimitReached.groups) ? 'limit-reached' : '' %>">
                    <%= typeof stats !== 'undefined' ? stats.totalGroups || 0 : 0 %>/<%= typeof currentAdmin !== 'undefined' ? (currentAdmin.maxGroups === Infinity ? '∞' : currentAdmin.maxGroups) : 0 %>
                    <span class="limit-label">已用/上限</span>
                </div>
            </div>
            <div class="stat-card">
                <h3><i class="fas fa-envelope"></i> 今日消息</h3>
                <div class="stat-number <%= (typeof isLimitReached !== 'undefined' && isLimitReached.messages) ? 'limit-reached' : '' %>">
                    <%= typeof stats !== 'undefined' ? stats.messagesToday || 0 : 0 %>/<%= typeof stats !== 'undefined' ? stats.messagesLimit || 20 : 20 %>
                    <span class="limit-label">已用/上限</span>
                </div>
            </div>
            <% if(typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                <div class="stat-card">
                    <h3><i class="fas fa-users"></i> 管理员</h3>
                    <div class="stat-number"><%= typeof stats !== 'undefined' ? stats.totalAdmins || 0 : 0 %></div>
                </div>
            <% } %>
        </div>

        <!-- Payment Methods Table -->
        <div class="section-title">
            <h2><i class="fas fa-list-ul"></i> 支付通道管理</h2>
            <% if(typeof canAdd !== 'undefined' && canAdd && canAdd.paymentMethod !== false) { %>
                <a href="/admin/methods/new" class="btn-primary-sm"><i class="fas fa-plus"></i> 新增通道</a>
            <% } else { %>
                <a href="#" class="btn-primary-sm disabled" onclick="alert('已达支付方式上限，请升级方案')"><i class="fas fa-plus"></i> 新增通道</a>
            <% } %>
        </div>

        <div class="table-wrapper">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>Bot</th>
                            <th>支付通道名称</th>
                            <th>类型</th>
                            <th>银行标识</th>
                            <th>收款账号</th>
                            <th>可用状态</th>
                            <th>操作控制</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof methods !== 'undefined' && methods && methods.length > 0) { %>
                            <% methods.forEach(function(m) { %>
                                <tr id="row-<%= m._id %>">
                                    <td><span class="badge"><%= m.botId ? m.botId.name : '未分配' %></span></td>
                                    <td><strong><%= m.name %></strong></td>
                                    <td><span class="badge badge-type"><%= m.type %></span></td>
                                    <td><%= m.bankName %></td>
                                    <td><code><%= m.accountNumber %></code></td>
                                    <td>
                                        <span class="status-indicator <%= m.isActive ? 'active' : 'inactive' %>">
                                            <%= m.isActive ? '已启用' : '已停用' %>
                                        </span>
                                    </td>
                                    <td>
                                        <a href="/admin/methods/edit/<%= m._id %>" class="btn-edit"><i class="fas fa-edit"></i> 修改</a>
                                        <button onclick="purgeGate('<%= m._id %>')" class="btn-delete"><i class="fas fa-trash-alt"></i> 删除</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="empty-state">
                                    <i class="fas fa-inbox"></i>
                                    暂无支付方式，点击 <a href="/admin/methods/new">新建配置</a> 添加
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        function purgeGate(id) {
            if (!confirm("确定要永久删除此配置吗？")) return;
            fetch('/api/methods/' + id, { method: 'DELETE' })
                .then(function(res) { return res.json(); })
                .then(function(result) {
                    if (result.success) {
                        var row = document.getElementById('row-' + id);
                        if (row) row.remove();
                    } else {
                        alert('删除失败: ' + (result.error || '未知错误'));
                    }
                })
                .catch(function(e) {
                    alert('删除失败: ' + e.message);
                });
        }
    </script>
</body>
</html>
