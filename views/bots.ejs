<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bot 管理 · 控制台</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --bg-main: #f3f4f6;
            --panel-bg: #ffffff;
            --text-primary: #111827;
            --text-secondary: #6b7280;
            --text-muted: #9ca3af;
            --accent-primary: #6366f1;
            --accent-hover: #4f46e5;
            --accent-light: #eef2ff;
            --border-color: #e5e7eb;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            
            --status-active-bg: #d1fae5;
            --status-active-text: #065f46;
            --status-active-dot: #10b981;
            
            --status-inactive-bg: #fee2e2;
            --status-inactive-text: #991b1b;
            --status-inactive-dot: #ef4444;
            
            --card-radius: 16px;
            --transition-speed: 0.2s;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- Header Navigation Bar --- */
        .app-bar {
            background: #ffffff;
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            color: var(--text-primary);
            padding: 0.85rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            box-shadow: var(--shadow-sm);
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255, 255, 255, 0.95);
        }

        .app-bar h1 {
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-primary);
        }

        .app-bar h1 i {
            color: var(--accent-primary);
            font-size: 1.35rem;
            background: var(--accent-light);
            padding: 8px;
            border-radius: 12px;
        }

        .app-bar div {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        /* --- Global Buttons --- */
        .btn-secondary, .btn-danger {
            padding: 0.5rem 1.1rem;
            border-radius: 10px;
            font-weight: 500;
            font-size: 0.875rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid transparent;
        }

        .btn-secondary {
            background: var(--bg-main);
            color: var(--text-secondary);
            border-color: var(--border-color);
        }

        .btn-secondary:hover {
            background: var(--border-color);
            color: var(--text-primary);
        }

        .btn-danger {
            background: #fef2f2;
            color: #dc2626;
            border-color: #fecaca;
        }

        .btn-danger:hover {
            background: #dc2626;
            color: white;
            box-shadow: 0 4px 12px rgba(220, 38, 38, 0.25);
        }

        /* --- Layout Main Elements --- */
        .viewport-container {
            max-width: 1440px;
            margin: 2rem auto;
            padding: 0 2.5rem;
            width: 100%;
            flex: 1;
        }

        .admin-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .admin-controls .stats {
            display: flex;
            gap: 1.5rem;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .admin-controls .stats span {
            background: white;
            padding: 0.5rem 1rem;
            border-radius: 10px;
            border: 1px solid var(--border-color);
        }

        .btn-primary {
            background: var(--accent-primary);
            color: white;
            padding: 0.65rem 1.5rem;
            border-radius: 10px;
            font-weight: 500;
            border: none;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-primary:hover {
            background: var(--accent-hover);
            box-shadow: 0 6px 16px rgba(99, 102, 241, 0.4);
            transform: translateY(-1px);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .btn-primary.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }

        /* --- Limit Warning --- */
        .limit-warning {
            background: #fffbeb;
            border: 1px solid #f59e0b;
            color: #92400e;
            padding: 0.8rem 1.5rem;
            border-radius: 12px;
            margin: 0 2.5rem 1.5rem 2.5rem;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .limit-warning i {
            color: #f59e0b;
            font-size: 1.2rem;
        }

        .limit-warning .btn-upgrade {
            margin-left: auto;
            background: #f59e0b;
            color: white;
            padding: 0.4rem 1.2rem;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.8rem;
            transition: all var(--transition-speed);
        }

        .limit-warning .btn-upgrade:hover {
            background: #d97706;
            transform: translateY(-1px);
        }

        /* --- Modern Data Table Rendering --- */
        .table-wrapper {
            background: white;
            border-radius: var(--card-radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        .table-scroll {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
            min-width: 900px;
            text-align: left;
        }

        th {
            padding: 1rem 1.5rem;
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            background: #f9fafb;
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            color: var(--text-primary);
            background: white;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: #f9fafb;
        }

        td strong {
            font-weight: 600;
            color: var(--text-primary);
        }

        td strong i {
            color: var(--accent-primary);
            margin-right: 6px;
        }

        code {
            background: #f1f5f9;
            padding: 0.15rem 0.6rem;
            border-radius: 6px;
            font-size: 0.8rem;
            color: #1e293b;
            font-family: 'Menlo', 'Monaco', monospace;
        }

        /* --- Decorative Badges & Indicators --- */
        .badge-plan {
            display: inline-block;
            padding: 0.25rem 0.7rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .badge-demo { background: #f3f4f6; color: #4b5563; }
        .badge-starter { background: #d1fae5; color: #065f46; }
        .badge-pro { background: #fef3c7; color: #92400e; }
        .badge-enterprise { background: #ede9fe; color: #5b21b6; }
        .badge-lifetime { background: #fbbf24; color: #000; }

        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .status-indicator::before {
            content: "";
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }

        .status-indicator.active {
            background: var(--status-active-bg);
            color: var(--status-active-text);
        }

        .status-indicator.active::before {
            background: var(--status-active-dot);
        }

        .status-indicator.inactive {
            background: var(--status-inactive-bg);
            color: var(--status-inactive-text);
        }

        .status-indicator.inactive::before {
            background: var(--status-inactive-dot);
        }

        /* --- Row Inline Actions Buttons --- */
        .btn-edit, .btn-delete, .btn-stats {
            border: none;
            background: transparent;
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.35rem 0.75rem;
            border-radius: 8px;
            transition: all 0.15s ease;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .btn-edit {
            color: var(--accent-primary);
            background: var(--accent-light);
        }

        .btn-edit:hover {
            background: #dbeafe;
            color: var(--accent-hover);
        }

        .btn-delete {
            color: #dc2626;
            background: #fef2f2;
        }

        .btn-delete:hover {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-stats {
            color: #4338ca;
            background: #e0e7ff;
        }

        .btn-stats:hover {
            background: #c7d2fe;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem !important;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 2.5rem;
            display: block;
            margin-bottom: 1rem;
            color: var(--border-color);
        }

        .empty-state a {
            color: var(--accent-primary);
            text-decoration: none;
            font-weight: 500;
        }

        .empty-state a:hover {
            text-decoration: underline;
        }

        /* --- Modern Overlay Window Structures --- */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(17, 24, 39, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 1.5rem;
            animation: fadeIn 0.2s ease-out;
        }

        .modal-overlay.active {
            display: flex !important;
        }

        .modal-content {
            background: #ffffff;
            border-radius: 20px;
            max-width: 650px;
            width: 100%;
            padding: 2rem;
            box-shadow: var(--shadow-xl);
            border: 1px solid var(--border-color);
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .modal-header h2 {
            font-weight: 600;
            font-size: 1.35rem;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-header h2 i {
            color: var(--accent-primary);
        }

        .close-btn {
            font-size: 1.5rem;
            font-weight: 300;
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.15s;
            background: none;
            border: none;
            line-height: 1;
            padding: 4px 8px;
            border-radius: 8px;
        }

        .close-btn:hover {
            color: var(--text-primary);
            background: var(--bg-main);
            transform: rotate(90deg);
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

        .form-group label {
            font-weight: 500;
            font-size: 0.825rem;
            color: var(--text-secondary);
            display: block;
            margin-bottom: 0.3rem;
        }

        .form-group label i {
            margin-right: 6px;
            color: var(--text-muted);
            width: 16px;
            text-align: center;
        }

        .form-group label .required {
            color: #ef4444;
            margin-left: 2px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 0.6rem 0.9rem;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            font-size: 0.9rem;
            background: #ffffff;
            transition: all var(--transition-speed);
            outline: none;
            color: var(--text-primary);
        }

        .form-group input:focus,
        .form-group select:focus {
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        }

        .form-group input::placeholder {
            color: var(--text-muted);
        }

        .form-hint {
            color: var(--text-muted);
            font-size: 0.75rem;
            margin-top: 0.35rem;
            display: block;
        }

        .section-divider {
            border: none;
            border-top: 1px solid var(--border-color);
            margin: 1.2rem 0;
        }

        .section-title {
            color: var(--text-primary);
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        /* --- Plan Details --- */
        .plan-details {
            background: #f9fafb;
            padding: 1rem 1.2rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            margin: 0.5rem 0 0 0;
        }

        .plan-details h4 {
            margin: 0 0 0.5rem 0;
            color: var(--text-primary);
            font-weight: 600;
            font-size: 0.9rem;
        }

        .plan-details ul {
            margin: 0;
            padding-left: 1.2rem;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 4px 8px;
        }

        .plan-details ul li {
            font-size: 0.85rem;
            color: var(--text-secondary);
            padding: 0.1rem 0;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 2rem;
        }

        .modal-actions .btn-secondary-action {
            background: #f3f4f6;
            color: var(--text-secondary);
            border: none;
            padding: 0.6rem 1.5rem;
            border-radius: 10px;
            font-weight: 500;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all var(--transition-speed);
        }

        .modal-actions .btn-secondary-action:hover {
            background: #e5e7eb;
            color: var(--text-primary);
        }

        .modal-actions .btn-primary {
            padding: 0.6rem 1.75rem;
        }

        /* --- Scrollbar Performance Modernization --- */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #9ca3af;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.96); }
            to { opacity: 1; transform: scale(1); }
        }

        /* --- Stats Modal --- */
        #statsModal .modal-content {
            max-width: 500px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .stats-card {
            background: #f9fafb;
            padding: 0.8rem;
            border-radius: 10px;
            border: 1px solid var(--border-color);
        }

        .stats-card .label {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .stats-card .value {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text-primary);
            margin-top: 0.1rem;
        }

        .stats-divider {
            border: none;
            border-top: 1px solid var(--border-color);
            margin: 0.8rem 0;
        }

        .stats-section-title {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-primary);
            margin-bottom: 0.6rem;
            margin-top: 0.2rem;
        }

        /* --- Responsive Adaptive Controls --- */
        @media (max-width: 768px) {
            .app-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
                padding: 1rem 1.5rem;
            }
            .viewport-container {
                padding: 0 1rem;
                margin: 1.5rem auto;
            }
            .limit-warning {
                margin: 0 1rem 1.5rem 1rem;
                flex-direction: column;
                text-align: center;
            }
            .limit-warning .btn-upgrade {
                margin-left: 0;
            }
            .modal-content {
                padding: 1.5rem;
                margin: 0.5rem;
            }
            th, td {
                padding: 0.75rem 1rem;
                font-size: 0.8rem;
            }
            .admin-controls {
                flex-direction: column;
                align-items: stretch;
            }
            .admin-controls .stats {
                flex-wrap: wrap;
                gap: 0.75rem;
            }
            .admin-controls .stats span {
                font-size: 0.8rem;
                padding: 0.4rem 0.75rem;
            }
            .modal-actions {
                flex-direction: column;
            }
            .modal-actions button {
                justify-content: center;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
            .plan-details ul {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 480px) {
            .app-bar h1 {
                font-size: 1rem;
            }
            .app-bar h1 i {
                font-size: 1.1rem;
                padding: 6px;
            }
            .btn-secondary, .btn-danger {
                font-size: 0.75rem;
                padding: 0.4rem 0.8rem;
            }
            .btn-primary {
                font-size: 0.8rem;
                padding: 0.5rem 1rem;
            }
            .modal-header h2 {
                font-size: 1.1rem;
            }
            .modal-content {
                padding: 1.25rem;
            }
            th, td {
                padding: 0.6rem 0.75rem;
                font-size: 0.75rem;
            }
            .stats-grid {
                grid-template-columns: 1fr;
            }
            .plan-details ul {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header class="app-bar">
        <h1><i class="fas fa-robot"></i> Bot 管理</h1>
        <div>
            <a href="/admin/dashboard" class="btn-secondary"><i class="fas fa-chart-pie"></i> 仪表板</a>
            <a href="/admin/logout" class="btn-danger"><i class="fas fa-sign-out-alt"></i> 退出</a>
        </div>
    </header>

    <!-- Plan Limit Warning - Safe check for currentAdmin -->
    <% if(typeof currentAdmin !== 'undefined' && currentAdmin && !isSuperAdmin) { %>
        <div class="limit-warning">
            <i class="fas fa-info-circle"></i>
            <span>
                <strong>Bot 使用情况:</strong> 
                <%= currentAdmin.currentBots %>/<%= currentAdmin.maxBots === Infinity ? '∞' : currentAdmin.maxBots %> 
                (<%= currentAdmin.isWithinLimits('bots') ? '✅ 可添加' : '❌ 已达上限' %>)
            </span>
            <% if(!currentAdmin.isWithinLimits('bots')) { %>
                <a href="/admin/plans" class="btn-upgrade">升级方案</a>
            <% } %>
        </div>
    <% } %>

    <main class="viewport-container">
        <div class="admin-controls">
            <div class="stats">
                <span><i class="fas fa-robot" style="color: var(--accent-primary);"></i> 总计: <%= typeof bots !== 'undefined' && bots ? bots.length : 0 %></span>
                <span><i class="fas fa-check-circle" style="color: #10b981;"></i> 在线: <%= typeof bots !== 'undefined' && bots ? bots.filter(b => b.isActive && b.isOnline).length : 0 %></span>
                <span><i class="fas fa-circle" style="color: #ef4444;"></i> 离线: <%= typeof bots !== 'undefined' && bots ? bots.filter(b => b.isActive && !b.isOnline).length : 0 %></span>
            </div>
            <button onclick="showCreateForm()" class="btn-primary <%= (typeof currentAdmin !== 'undefined' && currentAdmin && !currentAdmin.isWithinLimits('bots') && !isSuperAdmin) ? 'disabled' : '' %>">
                <i class="fas fa-plus-circle"></i> 添加 Bot
            </button>
        </div>

        <div class="table-wrapper">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>Bot 名称</th>
                            <th>Token</th>
                            <th>方案</th>
                            <th>状态</th>
                            <th>使用量</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof bots !== 'undefined' && bots && bots.length > 0) { %>
                            <% bots.forEach(function(bot) { %>
                                <tr id="bot-<%= bot._id %>">
                                    <td><strong><i class="fas fa-robot"></i> <%= bot.name %></strong></td>
                                    <td><code><%= bot.botToken ? bot.botToken.substring(0, 12) + '...' : 'N/A' %></code></td>
                                    <td>
                                        <span class="badge-plan badge-<%= bot.plan %>">
                                            <%= bot.plan ? bot.plan.toUpperCase() : 'DEMO' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="status-indicator <%= bot.isActive && bot.isOnline ? 'active' : 'inactive' %>">
                                            <%= bot.isActive ? (bot.isOnline ? '🟢 在线' : '🔴 离线') : '⛔ 已停用' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span style="font-size:0.8rem;">
                                            📨 <%= bot.currentMessages %>/<%= bot.maxMessages === Infinity ? '∞' : bot.maxMessages %>
                                        </span>
                                    </td>
                                    <td>
                                        <button onclick="viewStats('<%= bot._id %>')" class="btn-stats">
                                            <i class="fas fa-chart-bar"></i> 统计
                                        </button>
                                        <button onclick="editBot('<%= bot._id %>')" class="btn-edit"><i class="fas fa-edit"></i> 编辑</button>
                                        <button onclick="deleteBot('<%= bot._id %>')" class="btn-delete"><i class="fas fa-trash-alt"></i> 删除</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="empty-state">
                                    <i class="fas fa-robot"></i>
                                    暂无 Bot，点击 <a href="#" onclick="showCreateForm(); return false;">添加 Bot</a> 创建第一个
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- Create/Edit Modal -->
    <div id="botModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fas fa-robot"></i> <span id="modalTitle">添加 Bot</span></h2>
                <button class="close-btn" onclick="closeModal()">&times;</button>
            </div>
            <form id="botForm">
                <input type="hidden" id="botId" name="id">
                
                <div class="form-group">
                    <label><i class="fas fa-tag"></i> Bot 名称 <span class="required">*</span></label>
                    <input type="text" id="name" name="name" placeholder="例如: 支付机器人" required>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-key"></i> Bot Token <span class="required">*</span></label>
                    <input type="text" id="botToken" name="botToken" placeholder="例如: 123456789:ABCdefGHIjkl..." required>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-align-left"></i> 描述</label>
                    <input type="text" id="description" name="description" placeholder="简短描述">
                </div>

                <div class="form-group">
                    <label><i class="fas fa-crown"></i> 方案</label>
                    <select id="plan" name="plan" <%= isSuperAdmin ? '' : 'disabled' %>>
                        <% if(typeof plans !== 'undefined' && plans && plans.length > 0) { %>
                            <% plans.forEach(function(plan) { %>
                                <option value="<%= plan.name %>">
                                    <%= plan.displayName %> - <%= plan.maxMessages === Infinity ? '∞' : plan.maxMessages %>条消息 ($<%= plan.price %>)
                                </option>
                            <% }); %>
                        <% } else { %>
                            <option value="demo">Demo - 20条消息/天</option>
                        <% } %>
                    </select>
                    <% if(!isSuperAdmin) { %>
                        <span class="form-hint">你的方案: <strong><%= typeof currentAdmin !== 'undefined' && currentAdmin ? currentAdmin.plan.toUpperCase() : 'DEMO' %></strong> - 只能创建此方案的Bot</span>
                    <% } %>
                </div>

                <div class="plan-details" id="planDetails">
                    <h4>📊 方案详情</h4>
                    <ul>
                        <li>📨 <span id="planMessages">20</span> 条消息</li>
                        <li>👥 <span id="planAdmins">0</span> 个管理员</li>
                        <li>💳 <span id="planMethods">5</span> 个支付方式</li>
                        <li>📢 <span id="planGroups">1</span> 个群组</li>
                        <li>💰 价格: $<span id="planPrice">0</span> <span id="planInterval">/forever</span></li>
                    </ul>
                </div>

                <hr class="section-divider">

                <div class="section-title"><i class="fas fa-cog"></i> Telegram 配置</div>

                <div class="form-group">
                    <label><i class="fas fa-store"></i> 商家 Chat ID <span class="required">*</span></label>
                    <input type="text" id="merchantChatId" name="merchantChatId" placeholder="例如: 000000 或 -09111111001" required>
                    <span class="form-hint">商家接收转账凭证的群组或个人ID</span>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-users"></i> 主群组 Chat ID <span class="required">*</span></label>
                    <input type="text" id="mainGroupChatId" name="mainGroupChatId" placeholder="例如: -09111111001" required>
                    <span class="form-hint">客户群组ID，客户发送消息的群组</span>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-user-tie"></i> 所有者 ID</label>
                    <input type="text" id="ownerId" name="ownerId" placeholder="例如: 000000">
                    <span class="form-hint">Bot 所有者的 Telegram ID（可选）</span>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-user-tag"></i> 所有者用户名</label>
                    <input type="text" id="ownerUsername" name="ownerUsername" placeholder="例如: @username">
                    <span class="form-hint">Bot 所有者的 Telegram 用户名（可选）</span>
                </div>

                <hr class="section-divider">

                <div class="form-group">
                    <label><i class="fas fa-toggle-on"></i> 状态</label>
                    <select id="isActive" name="isActive">
                        <option value="true">已启用</option>
                        <option value="false">已停用</option>
                    </select>
                </div>

                <div class="modal-actions">
                    <button type="submit" class="btn-primary"><i class="fas fa-save"></i> 保存</button>
                    <button type="button" onclick="closeModal()" class="btn-secondary-action">取消</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Stats Modal -->
    <div id="statsModal" class="modal-overlay">
        <div class="modal-content" style="max-width: 500px;">
            <div class="modal-header">
                <h2><i class="fas fa-chart-bar"></i> Bot 统计</h2>
                <button class="close-btn" onclick="closeStatsModal()">&times;</button>
            </div>
            <div id="statsContent">
                <p>加载中...</p>
            </div>
        </div>
    </div>

    <script>
        // Store the bot ID for edit
        var editingBotId = null;

        // Show create form
        function showCreateForm() {
            // Check if user can add more bots
            <% if(typeof currentAdmin !== 'undefined' && currentAdmin && !isSuperAdmin) { %>
                if (!<%= currentAdmin.isWithinLimits('bots') %>) {
                    alert('已达到 Bot 上限！请升级方案。');
                    return;
                }
            <% } %>;
            
            editingBotId = null;
            document.getElementById('modalTitle').textContent = '添加 Bot';
            document.getElementById('botForm').reset();
            document.getElementById('botId').value = '';
            document.getElementById('botModal').style.display = 'flex';
            document.getElementById('botModal').classList.add('active');
            
            var planSelect = document.getElementById('plan');
            if (planSelect) {
                updatePlanDetails(planSelect.value);
            }
        }

        // Close modal
        function closeModal() {
            document.getElementById('botModal').style.display = 'none';
            document.getElementById('botModal').classList.remove('active');
        }

        // Close stats modal
        function closeStatsModal() {
            document.getElementById('statsModal').style.display = 'none';
            document.getElementById('statsModal').classList.remove('active');
        }

        // Update plan details when plan changes
        document.getElementById('plan').addEventListener('change', function() {
            updatePlanDetails(this.value);
        });

        function updatePlanDetails(planName) {
            var planOptions = document.getElementById('plan').options;
            var selectedPlan = null;
            
            for (var i = 0; i < planOptions.length; i++) {
                if (planOptions[i].value === planName) {
                    selectedPlan = planOptions[i];
                    break;
                }
            }
            
            if (selectedPlan) {
                var text = selectedPlan.text;
                var messagesMatch = text.match(/(\d+|∞)\s*条消息/);
                var priceMatch = text.match(/\$(\d+)/);
                
                if (messagesMatch) {
                    document.getElementById('planMessages').textContent = messagesMatch[1];
                }
                
                var planDefaults = {
                    'demo': { messages: 20, admins: 0, methods: 5, groups: 1, price: 0, interval: 'forever' },
                    'starter': { messages: Infinity, admins: 0, methods: 5, groups: 2, price: 29, interval: 'monthly' },
                    'pro': { messages: Infinity, admins: 0, methods: 7, groups: 5, price: 99, interval: 'monthly' },
                    'enterprise': { messages: Infinity, admins: 0, methods: Infinity, groups: 10, price: 299, interval: 'monthly' }
                };
                
                var defaults = planDefaults[planName] || planDefaults.demo;
                if (!messagesMatch) {
                    document.getElementById('planMessages').textContent = defaults.messages === Infinity ? '∞' : defaults.messages;
                }
                document.getElementById('planAdmins').textContent = defaults.admins === Infinity ? '∞' : defaults.admins;
                document.getElementById('planMethods').textContent = defaults.methods === Infinity ? '∞' : defaults.methods;
                document.getElementById('planGroups').textContent = defaults.groups === Infinity ? '∞' : defaults.groups;
                document.getElementById('planPrice').textContent = defaults.price;
                document.getElementById('planInterval').textContent = defaults.interval === 'forever' ? '(永久)' : '/' + defaults.interval;
            }
        }

        // Edit bot
        function editBot(id) {
            editingBotId = id;
            document.getElementById('modalTitle').textContent = '编辑 Bot';
            document.getElementById('botId').value = id;

            fetch('/admin/api/bots/' + id)
                .then(function(res) {
                    if (!res.ok) throw new Error('Failed to fetch bot');
                    return res.json();
                })
                .then(function(data) {
                    document.getElementById('name').value = data.name || '';
                    document.getElementById('botToken').value = data.botToken || '';
                    document.getElementById('description').value = data.description || '';
                    document.getElementById('plan').value = data.plan || 'demo';
                    document.getElementById('merchantChatId').value = data.merchantChatId || '';
                    document.getElementById('mainGroupChatId').value = data.mainGroupChatId || '';
                    document.getElementById('ownerId').value = data.ownerId || '';
                    document.getElementById('ownerUsername').value = data.ownerUsername || '';
                    document.getElementById('isActive').value = data.isActive ? 'true' : 'false';
                    
                    updatePlanDetails(data.plan || 'demo');
                    document.getElementById('botModal').style.display = 'flex';
                    document.getElementById('botModal').classList.add('active');
                })
                .catch(function(err) {
                    alert('加载 Bot 数据失败: ' + err.message);
                    console.error('Edit bot error:', err);
                });
        }

        // Form submit
        document.getElementById('botForm').addEventListener('submit', function(e) {
            e.preventDefault();

            var id = document.getElementById('botId').value;
            var data = {
                name: document.getElementById('name').value.trim(),
                botToken: document.getElementById('botToken').value.trim(),
                description: document.getElementById('description').value.trim(),
                plan: document.getElementById('plan').value,
                merchantChatId: document.getElementById('merchantChatId').value.trim(),
                mainGroupChatId: document.getElementById('mainGroupChatId').value.trim(),
                ownerId: document.getElementById('ownerId').value.trim(),
                ownerUsername: document.getElementById('ownerUsername').value.trim(),
                isActive: document.getElementById('isActive').value === 'true'
            };

            if (!data.name || !data.botToken) {
                alert('请填写所有必填字段');
                return;
            }

            if (!data.merchantChatId) {
                alert('请输入商家 Chat ID');
                document.getElementById('merchantChatId').focus();
                return;
            }

            if (!data.mainGroupChatId) {
                alert('请输入主群组 Chat ID');
                document.getElementById('mainGroupChatId').focus();
                return;
            }

            var url = id ? '/admin/bots/' + id : '/admin/bots';
            var method = id ? 'PUT' : 'POST';

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(function(res) {
                return res.json();
            })
            .then(function(result) {
                if (result.success) {
                    location.reload();
                } else {
                    alert('错误: ' + (result.error || '操作失败'));
                }
            })
            .catch(function(err) {
                alert('请求失败: ' + err.message);
                console.error('Submit error:', err);
            });
        });

        // Delete bot
        function deleteBot(id) {
            if (!confirm('确定要永久删除此 Bot 吗？所有关联数据将被删除。')) return;

            fetch('/admin/bots/' + id, { method: 'DELETE' })
                .then(function(res) {
                    return res.json();
                })
                .then(function(result) {
                    if (result.success) {
                        var row = document.getElementById('bot-' + id);
                        if (row) row.remove();
                        alert('Bot 删除成功！');
                    } else {
                        alert('错误: ' + (result.error || '删除失败'));
                    }
                })
                .catch(function(err) {
                    alert('请求失败: ' + err.message);
                    console.error('Delete error:', err);
                });
        }

        // View stats
        function viewStats(id) {
            fetch('/admin/api/bots/' + id + '/stats')
                .then(function(res) {
                    if (!res.ok) throw new Error('Failed to fetch stats');
                    return res.json();
                })
                .then(function(stats) {
                    var html = '<div style="padding: 0.5rem 0;">' +
                        '<div class="stats-section-title">📊 使用情况</div>' +
                        '<div class="stats-grid">' +
                            '<div class="stats-card">' +
                                '<div class="label">📨 消息</div>' +
                                '<div class="value">' + stats.usage.messages + '</div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">👥 管理员</div>' +
                                '<div class="value">' + stats.usage.admins + '</div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">💳 支付方式</div>' +
                                '<div class="value">' + stats.usage.paymentMethods + '</div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">📢 群组</div>' +
                                '<div class="value">' + stats.usage.groups + '</div>' +
                            '</div>' +
                        '</div>' +

                        '<hr class="stats-divider">' +

                        '<div class="stats-section-title">📈 总统计</div>' +
                        '<div class="stats-grid">' +
                            '<div class="stats-card" style="text-align:center;">' +
                                '<div class="label">处理消息</div>' +
                                '<div class="value">' + stats.total.messagesProcessed + '</div>' +
                            '</div>' +
                            '<div class="stats-card" style="text-align:center;">' +
                                '<div class="label">收到收据</div>' +
                                '<div class="value">' + stats.total.receiptsReceived + '</div>' +
                            '</div>' +
                            '<div class="stats-card" style="text-align:center;">' +
                                '<div class="label">交易数</div>' +
                                '<div class="value">' + stats.total.transactions + '</div>' +
                            '</div>' +
                        '</div>' +

                        '<hr class="stats-divider">' +

                        '<div class="stats-section-title">🏷️ 状态</div>' +
                        '<div class="stats-grid">' +
                            '<div class="stats-card">' +
                                '<div class="label">方案</div>' +
                                '<div class="value" style="font-size:1rem;">' + stats.plan.displayName + '</div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">价格</div>' +
                                '<div class="value">$' + stats.plan.price + '</div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">状态</div>' +
                                '<div class="value" style="font-size:1rem;">' + (stats.isActive ? '✅ 已启用' : '❌ 已停用') + '</div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">在线</div>' +
                                '<div class="value" style="font-size:1rem;">' + (stats.isOnline ? '🟢 在线' : '🔴 离线') + '</div>' +
                            '</div>' +
                        '</div>' +

                        '<hr class="stats-divider">' +

                        '<div class="stats-section-title">📌 Telegram 配置</div>' +
                        '<div class="stats-grid">' +
                            '<div class="stats-card">' +
                                '<div class="label">商家 Chat ID</div>' +
                                '<div style="font-size:0.85rem; font-weight:500; color:var(--text-primary); margin-top:0.2rem;"><code>' + (stats.merchantChatId || '未设置') + '</code></div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">主群组 Chat ID</div>' +
                                '<div style="font-size:0.85rem; font-weight:500; color:var(--text-primary); margin-top:0.2rem;"><code>' + (stats.mainGroupChatId || '未设置') + '</code></div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">所有者 ID</div>' +
                                '<div style="font-size:0.85rem; font-weight:500; color:var(--text-primary); margin-top:0.2rem;"><code>' + (stats.ownerId || '未设置') + '</code></div>' +
                            '</div>' +
                            '<div class="stats-card">' +
                                '<div class="label">所有者用户名</div>' +
                                '<div style="font-size:0.85rem; font-weight:500; color:var(--text-primary); margin-top:0.2rem;">' + (stats.ownerUsername || '未设置') + '</div>' +
                            '</div>' +
                        '</div>' +
                    '</div>';
                    
                    document.getElementById('statsContent').innerHTML = html;
                    document.getElementById('statsModal').style.display = 'flex';
                    document.getElementById('statsModal').classList.add('active');
                })
                .catch(function(err) {
                    alert('加载统计失败: ' + err.message);
                    console.error('Stats error:', err);
                });
        }

        // Close modals on outside click
        window.onclick = function(event) {
            var modal = document.getElementById('botModal');
            var statsModal = document.getElementById('statsModal');
            if (event.target === modal) {
                closeModal();
            }
            if (event.target === statsModal) {
                closeStatsModal();
            }
        };

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
                closeStatsModal();
            }
        });

        // Initialize plan details on page load
        document.addEventListener('DOMContentLoaded', function() {
            var planSelect = document.getElementById('plan');
            if (planSelect) {
                updatePlanDetails(planSelect.value);
            }
        });
    </script>
</body>
</html>
