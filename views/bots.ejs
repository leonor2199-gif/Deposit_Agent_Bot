<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bot 管理 · 控制台</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        body {
            background: #f4f7fc;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .app-bar {
            background: rgba(18, 28, 46, 0.88);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            color: white;
            padding: 0.9rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            box-shadow: 0 8px 24px rgba(0, 20, 40, 0.15);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }
        .app-bar h1 {
            font-weight: 600;
            font-size: 1.5rem;
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .app-bar h1 i { color: #60a5fa; }
        .app-bar > div {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .btn-secondary, .btn-danger {
            padding: 0.4rem 1.2rem;
            border-radius: 60px;
            font-weight: 500;
            font-size: 0.85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
            border: 1px solid transparent;
        }
        .btn-secondary {
            background: rgba(255, 255, 255, 0.08);
            color: #e8edf9;
            border-color: rgba(255, 255, 255, 0.08);
        }
        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.18);
            transform: translateY(-1px);
        }
        .btn-danger {
            background: rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            border-color: rgba(239, 68, 68, 0.2);
        }
        .btn-danger:hover {
            background: rgba(239, 68, 68, 0.3);
            color: #fff;
        }
        .limit-warning {
            background: #fef3c7;
            border: 1px solid #f59e0b;
            color: #92400e;
            padding: 0.8rem 1.5rem;
            border-radius: 16px;
            margin: 1rem 2rem;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .limit-warning i { color: #f59e0b; font-size: 1.2rem; }
        .limit-warning .btn-upgrade {
            margin-left: auto;
            background: #f59e0b;
            color: white;
            padding: 0.3rem 1.2rem;
            border-radius: 60px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.8rem;
        }
        .limit-warning .btn-upgrade:hover { background: #d97706; }
        .viewport-container {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 2rem;
            width: 100%;
            flex: 1;
        }
        .admin-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.8rem;
            flex-wrap: wrap;
            gap: 1rem;
        }
        .admin-controls h2 {
            font-weight: 600;
            font-size: 1.4rem;
            color: #0b1a33;
        }
        .btn-primary {
            background: #1e3a6b;
            color: white;
            padding: 0.7rem 1.8rem;
            border-radius: 60px;
            font-weight: 600;
            border: none;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            box-shadow: 0 6px 14px rgba(26, 67, 113, 0.25);
            transition: all 0.2s;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .btn-primary:hover {
            background: #14315a;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(18, 52, 97, 0.3);
        }
        .btn-primary.disabled {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }
        .table-wrapper {
            background: white;
            border-radius: 28px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.03), 0 4px 12px rgba(0, 20, 40, 0.04);
            overflow-x: auto;
            padding: 0.25rem;
            border: 1px solid rgba(255, 255, 255, 0.6);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.93rem;
            min-width: 900px;
        }
        th {
            text-align: left;
            padding: 1.2rem 1rem 0.9rem 1.5rem;
            font-weight: 600;
            color: #1f2a44;
            letter-spacing: 0.02em;
            font-size: 0.75rem;
            text-transform: uppercase;
            opacity: 0.7;
            border-bottom: 1px solid #eef2f6;
        }
        td {
            padding: 1rem 1rem 1rem 1.5rem;
            border-bottom: 1px solid #f0f4fa;
            vertical-align: middle;
            color: #1a2639;
        }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #f8faff; }
        td strong { font-weight: 600; color: #0b1a33; }
        code {
            background: #f1f5f9;
            padding: 0.15rem 0.6rem;
            border-radius: 30px;
            font-size: 0.8rem;
            color: #1e293b;
            font-family: 'Menlo', 'Monaco', monospace;
        }
        .badge-plan {
            display: inline-block;
            padding: 0.2rem 0.8rem;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
        }
        .badge-demo { background: #dbeafe; color: #1e3a8a; }
        .badge-starter { background: #d1fae5; color: #065f46; }
        .badge-pro { background: #fef3c7; color: #92400e; }
        .badge-enterprise { background: #ede9fe; color: #5b21b6; }
        .badge-lifetime { background: #fbbf24; color: #000; }
        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.2rem 0.9rem 0.2rem 0.7rem;
            border-radius: 40px;
            font-size: 0.78rem;
            font-weight: 500;
        }
        .status-indicator::before {
            content: "●";
            font-size: 0.6rem;
            margin-right: 2px;
        }
        .status-indicator.active {
            background: #dcfce7;
            color: #166534;
        }
        .status-indicator.active::before { color: #22c55e; }
        .status-indicator.inactive {
            background: #fee2e2;
            color: #991b1b;
        }
        .status-indicator.inactive::before { color: #ef4444; }
        .btn-edit, .btn-delete, .btn-stats {
            border: none;
            background: transparent;
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.3rem 0.9rem;
            border-radius: 40px;
            transition: all 0.15s;
            cursor: pointer;
            display: inline-block;
        }
        .btn-edit {
            color: #2563eb;
            background: #eff6ff;
        }
        .btn-edit:hover {
            background: #dbeafe;
            color: #1e40af;
        }
        .btn-delete {
            color: #b91c1c;
            background: #fee2e2;
        }
        .btn-delete:hover {
            background: #fecaca;
            color: #7f1d1d;
        }
        .btn-stats {
            color: #4338ca;
            background: #e0e7ff;
        }
        .btn-stats:hover {
            background: #c7d2fe;
        }
        .empty-state {
            text-align: center;
            padding: 3rem;
            color: #94a3b8;
        }
        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
        }
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }
        .modal-overlay.active {
            display: flex !important;
        }
        .modal-content {
            background: white;
            border-radius: 28px;
            max-width: 650px;
            width: 100%;
            padding: 2.5rem;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.2);
            animation: modalSlideIn 0.3s ease;
        }
        @keyframes modalSlideIn {
            from { transform: translateY(-20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.8rem;
        }
        .modal-header h2 {
            font-weight: 600;
            font-size: 1.7rem;
            color: #0b1a33;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .modal-header h2 i { color: #1e3a6b; }
        .close-btn {
            font-size: 2rem;
            font-weight: 300;
            color: #4b5563;
            cursor: pointer;
            transition: 0.2s;
            background: none;
            border: none;
            line-height: 1;
        }
        .close-btn:hover {
            color: #111827;
            transform: rotate(90deg);
        }
        .form-group {
            margin-bottom: 1.2rem;
        }
        .form-group label {
            font-weight: 500;
            font-size: 0.9rem;
            color: #1f2a44;
            display: block;
            margin-bottom: 0.3rem;
        }
        .form-group label i {
            margin-right: 6px;
            color: #1e3a6b;
        }
        .form-group label .required {
            color: #ef4444;
            margin-left: 2px;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 0.7rem 1rem;
            border: 1px solid #d1d9e6;
            border-radius: 16px;
            font-size: 0.95rem;
            background: white;
            transition: 0.2s;
            outline: none;
        }
        .form-group input:focus,
        .form-group select:focus {
            border-color: #1e3a6b;
            box-shadow: 0 0 0 4px rgba(30, 58, 107, 0.08);
        }
        .form-hint {
            color: #64748b;
            font-size: 0.75rem;
            margin-top: 0.25rem;
            display: block;
        }
        .section-divider {
            border: none;
            border-top: 1px solid #eef2f6;
            margin: 1.2rem 0;
        }
        .section-title {
            color: #0b1a33;
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }
        .plan-details {
            background: #f8fafd;
            padding: 1rem 1.2rem;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            margin: 0.5rem 0 0 0;
        }
        .plan-details h4 {
            margin: 0 0 0.5rem 0;
            color: #0b1a33;
        }
        .plan-details ul {
            margin: 0;
            padding-left: 1.2rem;
        }
        .plan-details ul li {
            font-size: 0.85rem;
            color: #4b5563;
            padding: 0.1rem 0;
        }
        .modal-actions {
            display: flex;
            gap: 12px;
            margin-top: 2rem;
            justify-content: flex-end;
        }
        .modal-actions .btn-secondary-action {
            background: #eef2f6;
            color: #1f2a44;
            padding: 0.7rem 2rem;
            border-radius: 60px;
            font-weight: 500;
            border: none;
            font-size: 0.95rem;
            cursor: pointer;
            transition: 0.15s;
        }
        .modal-actions .btn-secondary-action:hover {
            background: #dce2ec;
        }
        .modal-actions .btn-primary {
            padding: 0.7rem 2rem;
        }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #eef2f6; border-radius: 20px; }
        ::-webkit-scrollbar-thumb { background: #bac8d9; border-radius: 20px; }
        ::-webkit-scrollbar-thumb:hover { background: #9aadc4; }
        @media (max-width: 650px) {
            .app-bar { flex-direction: column; align-items: stretch; padding: 0.8rem 1.2rem; }
            .app-bar > div { justify-content: flex-start; }
            .viewport-container { padding: 0 1rem; margin: 1rem auto; }
            .admin-controls { flex-direction: column; align-items: stretch; }
            .admin-controls h2 { font-size: 1.2rem; }
            .modal-content { padding: 1.5rem; margin: 0.5rem; }
            .modal-header h2 { font-size: 1.3rem; }
            .modal-actions { flex-direction: column; }
            .modal-actions button { justify-content: center; }
            .limit-warning { margin: 0.5rem 1rem; flex-direction: column; text-align: center; }
            .limit-warning .btn-upgrade { margin-left: 0; }
        }
    </style>
</head>
<body>
    <header class="app-bar">
        <h1><i class="fas fa-robot"></i> Bot 管理控制台</h1>
        <div>
            <a href="/admin/dashboard" class="btn-secondary"><i class="fas fa-chart-pie"></i> 仪表板</a>
            <a href="/admin/logout" class="btn-danger"><i class="fas fa-sign-out-alt"></i> 退出</a>
        </div>
    </header>

    <!-- Plan Limit Warning - Safe check for currentAdmin -->
    <% if(typeof currentAdmin !== 'undefined' && currentAdmin && !isSuperAdmin) { %>
        <div class="limit-warning">
            <i class="fas fa-info-circle"></i>
            <span>
                <strong>Bot 使用情况:</strong> 
                <%= currentAdmin.currentBots %>/<%= currentAdmin.maxBots === Infinity ? '∞' : currentAdmin.maxBots %> 
                (<%= currentAdmin.isWithinLimits('bots') ? '✅ 可添加' : '❌ 已达上限' %>)
            </span>
            <% if(!currentAdmin.isWithinLimits('bots')) { %>
                <a href="/admin/plans" class="btn-upgrade">升级方案</a>
            <% } %>
        </div>
    <% } %>

    <main class="viewport-container">
        <div class="admin-controls">
            <h2><i class="fas fa-robot" style="color:#1e3a6b;"></i> 所有 Bot</h2>
            <button onclick="showCreateForm()" class="btn-primary <%= (typeof currentAdmin !== 'undefined' && currentAdmin && !currentAdmin.isWithinLimits('bots') && !isSuperAdmin) ? 'disabled' : '' %>">
                <i class="fas fa-plus-circle"></i> 添加 Bot
            </button>
        </div>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Bot 名称</th>
                        <th>Token</th>
                        <th>方案</th>
                        <th>状态</th>
                        <th>使用量</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(typeof bots !== 'undefined' && bots && bots.length > 0) { %>
                        <% bots.forEach(function(bot) { %>
                            <tr id="bot-<%= bot._id %>">
                                <td><strong><i class="fas fa-robot" style="color:#1e3a6b;"></i> <%= bot.name %></strong></td>
                                <td><code><%= bot.botToken ? bot.botToken.substring(0, 12) + '...' : 'N/A' %></code></td>
                                <td>
                                    <span class="badge-plan badge-<%= bot.plan %>">
                                        <%= bot.plan ? bot.plan.toUpperCase() : 'DEMO' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="status-indicator <%= bot.isActive && bot.isOnline ? 'active' : 'inactive' %>">
                                        <%= bot.isActive ? (bot.isOnline ? '🟢 在线' : '🔴 离线') : '⛔ 已停用' %>
                                    </span>
                                </td>
                                <td>
                                    <span style="font-size:0.8rem;">
                                        📨 <%= bot.currentMessages %>/<%= bot.maxMessages === Infinity ? '∞' : bot.maxMessages %>
                                    </span>
                                </td>
                                <td>
                                    <button onclick="viewStats('<%= bot._id %>')" class="btn-stats">
                                        <i class="fas fa-chart-bar"></i>
                                    </button>
                                    <button onclick="editBot('<%= bot._id %>')" class="btn-edit"><i class="fas fa-edit"></i></button>
                                    <button onclick="deleteBot('<%= bot._id %>')" class="btn-delete"><i class="fas fa-trash-alt"></i></button>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="empty-state">
                                <i class="fas fa-robot"></i>
                                暂无 Bot，点击 <a href="#" onclick="showCreateForm(); return false;" style="color: #2563eb;">添加 Bot</a> 创建第一个
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <!-- Create/Edit Modal -->
    <div id="botModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fas fa-robot"></i> <span id="modalTitle">添加 Bot</span></h2>
                <button class="close-btn" onclick="closeModal()">&times;</button>
            </div>
            <form id="botForm">
                <input type="hidden" id="botId" name="id">
                
                <div class="form-group">
                    <label><i class="fas fa-tag"></i> Bot 名称 <span class="required">*</span></label>
                    <input type="text" id="name" name="name" placeholder="例如: 支付机器人" required>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-key"></i> Bot Token <span class="required">*</span></label>
                    <input type="text" id="botToken" name="botToken" placeholder="例如: 123456789:ABCdefGHIjkl..." required>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-align-left"></i> 描述</label>
                    <input type="text" id="description" name="description" placeholder="简短描述">
                </div>

                <div class="form-group">
                    <label><i class="fas fa-crown"></i> 方案</label>
                    <select id="plan" name="plan" <%= isSuperAdmin ? '' : 'disabled' %>>
                        <% if(typeof plans !== 'undefined' && plans && plans.length > 0) { %>
                            <% plans.forEach(function(plan) { %>
                                <option value="<%= plan.name %>">
                                    <%= plan.displayName %> - <%= plan.maxMessages === Infinity ? '∞' : plan.maxMessages %>条消息 ($<%= plan.price %>)
                                </option>
                            <% }); %>
                        <% } else { %>
                            <option value="demo">Demo - 20条消息/天</option>
                        <% } %>
                    </select>
                    <% if(!isSuperAdmin) { %>
                        <span class="form-hint">你的方案: <strong><%= typeof currentAdmin !== 'undefined' && currentAdmin ? currentAdmin.plan.toUpperCase() : 'DEMO' %></strong> - 只能创建此方案的Bot</span>
                    <% } %>
                </div>

                <div class="plan-details" id="planDetails">
                    <h4>📊 方案详情</h4>
                    <ul>
                        <li>📨 <span id="planMessages">20</span> 条消息</li>
                        <li>👥 <span id="planAdmins">0</span> 个管理员</li>
                        <li>💳 <span id="planMethods">5</span> 个支付方式</li>
                        <li>📢 <span id="planGroups">1</span> 个群组</li>
                        <li>💰 价格: $<span id="planPrice">0</span> <span id="planInterval">/forever</span></li>
                    </ul>
                </div>

                <hr class="section-divider">

                <h4 class="section-title"><i class="fas fa-cog"></i> Telegram 配置</h4>

                <div class="form-group">
                    <label><i class="fas fa-store"></i> 商家 Chat ID <span class="required">*</span></label>
                    <input type="text" id="merchantChatId" name="merchantChatId" placeholder="例如: 8033870108 或 -1001234567890" required>
                    <span class="form-hint">商家接收转账凭证的群组或个人ID</span>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-users"></i> 主群组 Chat ID <span class="required">*</span></label>
                    <input type="text" id="mainGroupChatId" name="mainGroupChatId" placeholder="例如: -1009876543210" required>
                    <span class="form-hint">客户群组ID，客户发送消息的群组</span>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-user-tie"></i> 所有者 ID</label>
                    <input type="text" id="ownerId" name="ownerId" placeholder="例如: 8033870108">
                    <span class="form-hint">Bot 所有者的 Telegram ID（可选）</span>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-user-tag"></i> 所有者用户名</label>
                    <input type="text" id="ownerUsername" name="ownerUsername" placeholder="例如: @username">
                    <span class="form-hint">Bot 所有者的 Telegram 用户名（可选）</span>
                </div>

                <hr class="section-divider">

                <div class="form-group">
                    <label><i class="fas fa-toggle-on"></i> 状态</label>
                    <select id="isActive" name="isActive">
                        <option value="true">已启用</option>
                        <option value="false">已停用</option>
                    </select>
                </div>

                <div class="modal-actions">
                    <button type="submit" class="btn-primary"><i class="fas fa-save"></i> 保存</button>
                    <button type="button" onclick="closeModal()" class="btn-secondary-action">取消</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Stats Modal -->
    <div id="statsModal" class="modal-overlay">
        <div class="modal-content" style="max-width: 500px;">
            <div class="modal-header">
                <h2><i class="fas fa-chart-bar"></i> Bot 统计</h2>
                <button class="close-btn" onclick="closeStatsModal()">&times;</button>
            </div>
            <div id="statsContent">
                <p>加载中...</p>
            </div>
        </div>
    </div>

    <script>
        // Store the bot ID for edit
        var editingBotId = null;

        // Show create form
        function showCreateForm() {
            // Check if user can add more bots
            <% if(typeof currentAdmin !== 'undefined' && currentAdmin && !isSuperAdmin) { %>
                if (!<%= currentAdmin.isWithinLimits('bots') %>) {
                    alert('已达到 Bot 上限！请升级方案。');
                    return;
                }
            <% } %>;
            
            editingBotId = null;
            document.getElementById('modalTitle').textContent = '添加 Bot';
            document.getElementById('botForm').reset();
            document.getElementById('botId').value = '';
            document.getElementById('botModal').style.display = 'flex';
            document.getElementById('botModal').classList.add('active');
            
            var planSelect = document.getElementById('plan');
            if (planSelect) {
                updatePlanDetails(planSelect.value);
            }
        }

        // Close modal
        function closeModal() {
            document.getElementById('botModal').style.display = 'none';
            document.getElementById('botModal').classList.remove('active');
        }

        // Close stats modal
        function closeStatsModal() {
            document.getElementById('statsModal').style.display = 'none';
            document.getElementById('statsModal').classList.remove('active');
        }

        // Update plan details when plan changes
        document.getElementById('plan').addEventListener('change', function() {
            updatePlanDetails(this.value);
        });

        function updatePlanDetails(planName) {
            var planOptions = document.getElementById('plan').options;
            var selectedPlan = null;
            
            for (var i = 0; i < planOptions.length; i++) {
                if (planOptions[i].value === planName) {
                    selectedPlan = planOptions[i];
                    break;
                }
            }
            
            if (selectedPlan) {
                var text = selectedPlan.text;
                var messagesMatch = text.match(/(\d+|∞)\s*条消息/);
                var priceMatch = text.match(/\$(\d+)/);
                
                if (messagesMatch) {
                    document.getElementById('planMessages').textContent = messagesMatch[1];
                }
                
                var planDefaults = {
                    'demo': { messages: 20, admins: 0, methods: 5, groups: 1, price: 0, interval: 'forever' },
                    'starter': { messages: Infinity, admins: 0, methods: 5, groups: 2, price: 29, interval: 'monthly' },
                    'pro': { messages: Infinity, admins: 0, methods: 7, groups: 5, price: 99, interval: 'monthly' },
                    'enterprise': { messages: Infinity, admins: 0, methods: Infinity, groups: 10, price: 299, interval: 'monthly' }
                };
                
                var defaults = planDefaults[planName] || planDefaults.demo;
                if (!messagesMatch) {
                    document.getElementById('planMessages').textContent = defaults.messages === Infinity ? '∞' : defaults.messages;
                }
                document.getElementById('planAdmins').textContent = defaults.admins === Infinity ? '∞' : defaults.admins;
                document.getElementById('planMethods').textContent = defaults.methods === Infinity ? '∞' : defaults.methods;
                document.getElementById('planGroups').textContent = defaults.groups === Infinity ? '∞' : defaults.groups;
                document.getElementById('planPrice').textContent = defaults.price;
                document.getElementById('planInterval').textContent = defaults.interval === 'forever' ? '(永久)' : '/' + defaults.interval;
            }
        }

        // Edit bot
        function editBot(id) {
            editingBotId = id;
            document.getElementById('modalTitle').textContent = '编辑 Bot';
            document.getElementById('botId').value = id;

            fetch('/admin/api/bots/' + id)
                .then(function(res) {
                    if (!res.ok) throw new Error('Failed to fetch bot');
                    return res.json();
                })
                .then(function(data) {
                    document.getElementById('name').value = data.name || '';
                    document.getElementById('botToken').value = data.botToken || '';
                    document.getElementById('description').value = data.description || '';
                    document.getElementById('plan').value = data.plan || 'demo';
                    document.getElementById('merchantChatId').value = data.merchantChatId || '';
                    document.getElementById('mainGroupChatId').value = data.mainGroupChatId || '';
                    document.getElementById('ownerId').value = data.ownerId || '';
                    document.getElementById('ownerUsername').value = data.ownerUsername || '';
                    document.getElementById('isActive').value = data.isActive ? 'true' : 'false';
                    
                    updatePlanDetails(data.plan || 'demo');
                    document.getElementById('botModal').style.display = 'flex';
                    document.getElementById('botModal').classList.add('active');
                })
                .catch(function(err) {
                    alert('加载 Bot 数据失败: ' + err.message);
                    console.error('Edit bot error:', err);
                });
        }

        // Form submit
        document.getElementById('botForm').addEventListener('submit', function(e) {
            e.preventDefault();

            var id = document.getElementById('botId').value;
            var data = {
                name: document.getElementById('name').value.trim(),
                botToken: document.getElementById('botToken').value.trim(),
                description: document.getElementById('description').value.trim(),
                plan: document.getElementById('plan').value,
                merchantChatId: document.getElementById('merchantChatId').value.trim(),
                mainGroupChatId: document.getElementById('mainGroupChatId').value.trim(),
                ownerId: document.getElementById('ownerId').value.trim(),
                ownerUsername: document.getElementById('ownerUsername').value.trim(),
                isActive: document.getElementById('isActive').value === 'true'
            };

            if (!data.name || !data.botToken) {
                alert('请填写所有必填字段');
                return;
            }

            if (!data.merchantChatId) {
                alert('请输入商家 Chat ID');
                document.getElementById('merchantChatId').focus();
                return;
            }

            if (!data.mainGroupChatId) {
                alert('请输入主群组 Chat ID');
                document.getElementById('mainGroupChatId').focus();
                return;
            }

            var url = id ? '/admin/bots/' + id : '/admin/bots';
            var method = id ? 'PUT' : 'POST';

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(function(res) {
                return res.json();
            })
            .then(function(result) {
                if (result.success) {
                    location.reload();
                } else {
                    alert('错误: ' + (result.error || '操作失败'));
                }
            })
            .catch(function(err) {
                alert('请求失败: ' + err.message);
                console.error('Submit error:', err);
            });
        });

        // Delete bot
        function deleteBot(id) {
            if (!confirm('确定要永久删除此 Bot 吗？所有关联数据将被删除。')) return;

            fetch('/admin/bots/' + id, { method: 'DELETE' })
                .then(function(res) {
                    return res.json();
                })
                .then(function(result) {
                    if (result.success) {
                        var row = document.getElementById('bot-' + id);
                        if (row) row.remove();
                        alert('Bot 删除成功！');
                    } else {
                        alert('错误: ' + (result.error || '删除失败'));
                    }
                })
                .catch(function(err) {
                    alert('请求失败: ' + err.message);
                    console.error('Delete error:', err);
                });
        }

