<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>管理员管理 · 控制台</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --bg-main: #f3f4f6;
            --panel-bg: #ffffff;
            --text-primary: #111827;
            --text-secondary: #6b7280;
            --text-muted: #9ca3af;
            --accent-primary: #6366f1;
            --accent-hover: #4f46e5;
            --accent-light: #eef2ff;
            --border-color: #e5e7eb;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            
            --status-active-bg: #d1fae5;
            --status-active-text: #065f46;
            --status-active-dot: #10b981;
            
            --status-inactive-bg: #fee2e2;
            --status-inactive-text: #991b1b;
            --status-inactive-dot: #ef4444;
            
            --card-radius: 16px;
            --transition-speed: 0.2s;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- Header Navigation Bar --- */
        .app-bar {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            color: white;
            padding: 0.85rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            box-shadow: var(--shadow-md);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .app-bar h1 {
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-primary);
        }

        .app-bar h1 i {
            color: var(--accent-primary);
            font-size: 1.35rem;
            background: var(--accent-light);
            padding: 8px;
            border-radius: 12px;
        }

        .app-bar div {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        /* --- Global Buttons --- */
        .btn-secondary, .btn-danger {
            padding: 0.5rem 1.1rem;
            border-radius: 10px;
            font-weight: 500;
            font-size: 0.875rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid transparent;
        }

        .btn-secondary {
            background: var(--bg-main);
            color: var(--text-secondary);
            border-color: var(--border-color);
        }

        .btn-secondary:hover {
            background: var(--border-color);
            color: var(--text-primary);
        }

        .btn-danger {
            background: #fef2f2;
            color: #dc2626;
            border-color: #fecaca;
        }

        .btn-danger:hover {
            background: #dc2626;
            color: white;
            box-shadow: 0 4px 12px rgba(220, 38, 38, 0.25);
        }

        /* --- Layout Main Elements --- */
        .viewport-container {
            max-width: 1440px;
            margin: 2rem auto;
            padding: 0 2.5rem;
            width: 100%;
            flex: 1;
        }

        .admin-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .admin-controls .stats {
            display: flex;
            gap: 1.5rem;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .admin-controls .stats span {
            background: white;
            padding: 0.5rem 1rem;
            border-radius: 10px;
            border: 1px solid var(--border-color);
        }

        .btn-primary {
            background: var(--accent-primary);
            color: white;
            padding: 0.65rem 1.5rem;
            border-radius: 10px;
            font-weight: 500;
            border: none;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
            transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
        }

        .btn-primary:hover {
            background: var(--accent-hover);
            box-shadow: 0 6px 16px rgba(99, 102, 241, 0.4);
            transform: translateY(-1px);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        /* --- Modern Data Table Rendering --- */
        .table-wrapper {
            background: white;
            border-radius: var(--card-radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        .table-scroll {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
            min-width: 900px;
            text-align: left;
        }

        th {
            padding: 1rem 1.5rem;
            font-weight: 600;
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            background: #f9fafb;
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            color: var(--text-primary);
            background: white;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: #f9fafb;
        }

        td strong {
            font-weight: 600;
            color: var(--text-primary);
        }

        /* --- Decorative Badges & Indicators --- */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.75rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge-super {
            background: #ede9fe;
            color: #5b21b6;
            border: 1px solid #c4b5fd;
        }

        .badge-admin {
            background: #f3f4f6;
            color: #374151;
            border: 1px solid #d1d5db;
        }

        .badge-plan {
            display: inline-flex;
            padding: 0.25rem 0.7rem;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .badge-demo { background: #f3f4f6; color: #4b5563; }
        .badge-starter { background: #d1fae5; color: #065f46; }
        .badge-pro { background: #fef3c7; color: #92400e; }
        .badge-enterprise { background: #ede9fe; color: #5b21b6; }

        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .status-indicator::before {
            content: "";
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block;
            flex-shrink: 0;
        }

        .status-indicator.active {
            background: var(--status-active-bg);
            color: var(--status-active-text);
        }

        .status-indicator.active::before {
            background: var(--status-active-dot);
        }

        .status-indicator.inactive {
            background: var(--status-inactive-bg);
            color: var(--status-inactive-text);
        }

        .status-indicator.inactive::before {
            background: var(--status-inactive-dot);
        }

        /* --- Row Inline Actions Buttons --- */
        .btn-edit, .btn-delete {
            border: none;
            background: transparent;
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.35rem 0.75rem;
            border-radius: 8px;
            transition: all 0.15s ease;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .btn-edit {
            color: var(--accent-primary);
            background: var(--accent-light);
        }

        .btn-edit:hover {
            background: #dbeafe;
            color: var(--accent-hover);
        }

        .btn-delete {
            color: #dc2626;
            background: #fef2f2;
        }

        .btn-delete:hover {
            background: #fee2e2;
            color: #991b1b;
        }

        /* --- Modern Overlay Window Structures --- */
        .modal {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(17, 24, 39, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 1.5rem;
            animation: fadeIn 0.2s ease-out;
        }

        .modal.active {
            display: flex !important;
        }

        .modal-content {
            background: #ffffff;
            border-radius: 20px;
            max-width: 600px;
            width: 100%;
            padding: 2rem;
            box-shadow: var(--shadow-xl);
            border: 1px solid var(--border-color);
            max-height: 90vh;
            overflow-y: auto;
            position: relative;
        }

        .modal-content h2 {
            font-weight: 600;
            font-size: 1.35rem;
            color: var(--text-primary);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-content h2 i {
            color: var(--accent-primary);
        }

        .close {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            font-size: 1.25rem;
            color: var(--text-muted);
            cursor: pointer;
            transition: color 0.15s;
            line-height: 1;
            padding: 4px 8px;
            border-radius: 8px;
        }

        .close:hover {
            color: var(--text-primary);
            background: var(--bg-main);
        }

        form label {
            font-weight: 500;
            font-size: 0.825rem;
            color: var(--text-secondary);
            display: block;
            margin: 1rem 0 0.4rem 0;
        }

        form label i {
            margin-right: 6px;
            color: var(--text-muted);
            width: 16px;
            text-align: center;
        }

        form input, form select {
            width: 100%;
            padding: 0.6rem 0.9rem;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            font-size: 0.9rem;
            background: #ffffff;
            transition: all var(--transition-speed);
            outline: none;
            color: var(--text-primary);
        }

        form input:focus, form select:focus {
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
        }

        form input::placeholder {
            color: var(--text-muted);
        }

        /* --- Dynamic Feature Visualization Layouts --- */
        .plan-details {
            background: #f9fafb;
            padding: 1.1rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            margin-top: 0.75rem;
        }

        .plan-details h4 {
            font-size: 0.85rem;
            margin-bottom: 0.75rem;
            color: var(--text-primary);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        #adminPlanFeatures, #planLimitsDisplay {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: 8px;
            list-style: none;
            padding-left: 0 !important;
        }

        #planLimitsDisplay {
            margin-top: 0.75rem !important;
            padding-top: 0.75rem;
            border-top: 1px dashed var(--border-color);
        }

        .plan-details ul li {
            font-size: 0.8rem;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* --- Group Checklist Elements --- */
        #groupCheckboxes {
            background: #ffffff;
            border-radius: 10px;
            padding: 0.75rem;
            margin-top: 0.4rem;
            border: 1px solid var(--border-color);
            max-height: 160px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        #groupCheckboxes div {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.35rem 0.5rem;
            border-radius: 8px;
            transition: background 0.1s;
        }

        #groupCheckboxes div:hover {
            background: #f9fafb;
        }

        #groupCheckboxes input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: var(--accent-primary);
            margin: 0;
            cursor: pointer;
            flex-shrink: 0;
        }

        #groupCheckboxes label {
            margin: 0;
            font-weight: 400;
            font-size: 0.875rem;
            color: var(--text-primary);
            cursor: pointer;
            width: 100%;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem !important;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 2.5rem;
            display: block;
            margin-bottom: 1rem;
            color: var(--border-color);
        }

        .empty-state a {
            color: var(--accent-primary);
            text-decoration: none;
            font-weight: 500;
        }

        .empty-state a:hover {
            text-decoration: underline;
        }

        .actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 2rem;
        }

        .actions .btn-secondary-action {
            background: #f3f4f6;
            color: var(--text-secondary);
            border: none;
            padding: 0.6rem 1.5rem;
            border-radius: 10px;
            font-weight: 500;
            cursor: pointer;
            transition: all var(--transition-speed);
        }

        .actions .btn-secondary-action:hover {
            background: #e5e7eb;
            color: var(--text-primary);
        }

        .actions .btn-primary {
            padding: 0.6rem 1.75rem;
        }

        .form-hint {
            color: var(--text-muted);
            font-size: 0.75rem;
            margin-top: 0.35rem;
            display: block;
        }

        /* --- Scrollbar Performance Modernization --- */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #9ca3af;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.96); }
            to { opacity: 1; transform: scale(1); }
        }

        /* --- Responsive Adaptive Controls --- */
        @media (max-width: 768px) {
            .app-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
                padding: 1rem 1.5rem;
            }
            .viewport-container {
                padding: 0 1rem;
                margin: 1.5rem auto;
            }
            .modal-content {
                padding: 1.5rem;
            }
            th, td {
                padding: 0.75rem 1rem;
                font-size: 0.8rem;
            }
            .admin-controls {
                flex-direction: column;
                align-items: stretch;
            }
            .admin-controls .stats {
                flex-wrap: wrap;
                gap: 0.75rem;
            }
            .admin-controls .stats span {
                font-size: 0.8rem;
                padding: 0.4rem 0.75rem;
            }
            #adminPlanFeatures, #planLimitsDisplay {
                grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
            }
            .btn-edit, .btn-delete {
                font-size: 0.7rem;
                padding: 0.25rem 0.5rem;
            }
        }

        @media (max-width: 480px) {
            .app-bar h1 {
                font-size: 1rem;
            }
            .app-bar h1 i {
                font-size: 1.1rem;
                padding: 6px;
            }
            .btn-secondary, .btn-danger {
                font-size: 0.75rem;
                padding: 0.4rem 0.8rem;
            }
            .btn-primary {
                font-size: 0.8rem;
                padding: 0.5rem 1rem;
            }
            .modal-content {
                padding: 1.25rem;
            }
            th, td {
                padding: 0.6rem 0.75rem;
                font-size: 0.75rem;
            }
        }
    </style>
</head>
<body>
    <header class="app-bar">
        <h1><i class="fas fa-user-shield"></i> 管理员控制台</h1>
        <div>
            <a href="/admin/dashboard" class="btn-secondary"><i class="fas fa-chart-pie"></i> 仪表板</a>
            <a href="/admin/logout" class="btn-danger"><i class="fas fa-sign-out-alt"></i> 退出</a>
        </div>
    </header>
    <main class="viewport-container">
        <div class="admin-controls">
            <div class="stats">
                <span><i class="fas fa-users" style="color: var(--accent-primary);"></i> 总计: <%= typeof admins !== 'undefined' && admins ? admins.length : 0 %></span>
                <span><i class="fas fa-user-check" style="color: #10b981;"></i> 已启用: <%= typeof admins !== 'undefined' && admins ? admins.filter(a => a.isActive).length : 0 %></span>
                <span><i class="fas fa-user-slash" style="color: #ef4444;"></i> 已停用: <%= typeof admins !== 'undefined' && admins ? admins.filter(a => !a.isActive).length : 0 %></span>
            </div>
            <button onclick="showCreateForm()" class="btn-primary"><i class="fas fa-user-plus"></i> 创建管理员</button>
        </div>

        <div class="table-wrapper">
            <div class="table-scroll">
                <table>
                    <thead>
                        <tr>
                            <th>用户名</th>
                            <th>角色</th>
                            <th>方案</th>
                            <th>状态</th>
                            <th>可访问群组</th>
                            <th>创建者</th>
                            <th>最后登录</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof admins !== 'undefined' && admins && admins.length > 0) { %>
                            <% admins.forEach(function(admin) { %>
                                <tr id="admin-<%= admin._id %>">
                                    <td><strong><%= admin.username %></strong></td>
                                    <td>
                                        <span class="badge <%= admin.role === 'superadmin' ? 'badge-super' : 'badge-admin' %>">
                                            <%= admin.role === 'superadmin' ? '超级管理员' : '管理员' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge-plan badge-<%= admin.plan || 'demo' %>">
                                            <%= admin.plan ? admin.plan.toUpperCase() : 'DEMO' %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="status-indicator <%= admin.isActive ? 'active' : 'inactive' %>">
                                            <%= admin.isActive ? '已启用' : '已停用' %>
                                        </span>
                                    </td>
                                    <td><%= admin.accessibleGroups ? admin.accessibleGroups.length : 0 %></td>
                                    <td><%= admin.createdBy ? admin.createdBy.username : '系统' %></td>
                                    <td><%= admin.lastLogin ? new Date(admin.lastLogin).toLocaleString('zh-CN') : '未登录' %></td>
                                    <td>
                                        <button onclick="editAdmin('<%= admin._id %>')" class="btn-edit"><i class="fas fa-edit"></i> 编辑</button>
                                        <% if(admin._id.toString() !== adminData.id) { %>
                                            <button onclick="deleteAdmin('<%= admin._id %>')" class="btn-delete"><i class="fas fa-trash-alt"></i> 删除</button>
                                        <% } else { %>
                                            <span style="font-size:0.7rem; color:var(--text-muted); margin-left: 6px;">当前账号</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="empty-state">
                                    <i class="fas fa-users"></i>
                                    暂无管理员，点击 <a href="#" onclick="showCreateForm(); return false;">创建管理员</a> 添加第一个管理员
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <div id="adminModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal()"><i class="fas fa-times"></i></span>
            <h2><i class="fas fa-user-cog"></i> <span id="modalTitle">创建管理员</span></h2>
            <form id="adminForm">
                <input type="hidden" id="adminId" name="id">
                
                <label><i class="fas fa-user"></i> 用户名 *</label>
                <input type="text" id="username" name="username" placeholder="例如: zhangsan" required>

                <label><i class="fas fa-lock"></i> 密码 <span style="font-weight:400; color:var(--text-muted); font-size:0.8rem;">(创建时必填，编辑时留空)</span></label>
                <input type="password" id="password" name="password" placeholder="至少6位字符">

                <label><i class="fas fa-tag"></i> 角色</label>
                <select id="role" name="role">
                    <option value="admin">管理员</option>
                    <option value="superadmin">超级管理员</option>
                </select>

                <label><i class="fas fa-crown"></i> 方案</label>
                <select id="plan" name="plan">
                    <% if(typeof plans !== 'undefined' && plans && plans.length > 0) { %>
                        <% plans.forEach(function(plan) { %>
                            <option value="<%= plan.name %>">
                                <%= plan.displayName %> - <%= plan.price === 0 ? 'Free' : '$' + plan.price + '/' + plan.interval %>
                            </option>
                        <% }); %>
                    <% } else { %>
                        <option value="demo">Demo - 基础权限</option>
                        <option value="starter">Starter - 基础管理</option>
                        <option value="pro">Pro - 完整管理</option>
                        <option value="enterprise">Enterprise - 所有功能</option>
                    <% } %>
                </select>
                <span class="form-hint">选择决定该管理员权限和限制的方案</span>

                <div class="plan-details" id="adminPlanDetails">
                    <h4><i class="fas fa-chart-bar"></i> 方案功能</h4>
                    <ul id="adminPlanFeatures">
                        <li>✅ 查看分析</li>
                        <li>❌ 管理机器人</li>
                        <li>❌ 管理管理员</li>
                        <li>❌ 管理支付方式</li>
                        <li>❌ 管理群组</li>
                        <li>❌ 管理交易</li>
                    </ul>
                    <ul id="planLimitsDisplay">
                        <li>👥 管理员: 0</li>
                        <li>🤖 机器人: 1</li>
                        <li>💳 支付方式: 5</li>
                        <li>📢 群组: 1</li>
                        <li>📊 消息/天: 20</li>
                    </ul>
                </div>

                <label><i class="fas fa-toggle-on"></i> 状态</label>
                <select id="isActive" name="isActive">
                    <option value="true">已启用</option>
                    <option value="false">已停用</option>
                </select>

                <label><i class="fas fa-layer-group"></i> 可访问群组</label>
                <div id="groupCheckboxes">
                    <% if(typeof groups !== 'undefined' && groups && groups.length > 0) { %>
                        <% groups.forEach(function(group) { %>
                            <div>
                                <input type="checkbox" name="groups" value="<%= group._id %>" id="group-<%= group._id %>">
                                <label for="group-<%= group._id %>"><%= group.title %> (<%= group.chatId %>)</label>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div style="color:var(--text-muted); font-size:0.875rem; text-align:center; padding:0.5rem; width: 100%;">
                            <i class="fas fa-info-circle"></i> 暂无群组，请先创建群组
                        </div>
                    <% } %>
                </div>

                <div class="actions">
                    <button type="submit" class="btn-primary"><i class="fas fa-save"></i> 保存</button>
                    <button type="button" onclick="closeModal()" class="btn-secondary-action">取消</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Plan features mapping
        const planFeatures = {
            demo: {
                features: ['查看分析'],
                limits: { admins: 0, bots: 1, paymentMethods: 5, groups: 1, messages: 20 }
            },
            starter: {
                features: ['查看分析', '管理机器人', '管理支付方式', '管理群组', '管理交易'],
                limits: { admins: 0, bots: 2, paymentMethods: 5, groups: 2, messages: '∞' }
            },
            pro: {
                features: ['查看分析', '管理机器人', '管理支付方式', '管理群组', '管理交易', '导出数据', 'API访问'],
                limits: { admins: 0, bots: 5, paymentMethods: 7, groups: 5, messages: '∞' }
            },
            enterprise: {
                features: ['所有功能', '管理方案', '管理Webhook', '完整访问'],
                limits: { admins: 0, bots: 10, paymentMethods: '∞', groups: 10, messages: '∞' }
            }
        };

        let currentEditId = null;

        function updateAdminPlanDetails(planName) {
            if (!planName) planName = 'demo';
            const details = planFeatures[planName] || planFeatures.demo;
            const featuresList = document.getElementById('adminPlanFeatures');
            if (!featuresList) return;
            featuresList.innerHTML = '';
            
            const allFeatures = ['查看分析', '管理机器人', '管理管理员', '管理支付方式', '管理群组', '管理交易', '导出数据', 'API访问', '管理方案', '管理Webhook', '完整访问', '终身更新', '优先支持'];
            
            allFeatures.forEach(function(feature) {
                const li = document.createElement('li');
                const hasFeature = details.features && details.features.some(function(f) {
                    return feature.includes(f) || f.includes(feature);
                });
                li.innerHTML = hasFeature ? '<span>✅</span> ' + feature : '<span style="opacity: 0.4;">❌</span> ' + feature;
                featuresList.appendChild(li);
            });

            const limitsDisplay = document.getElementById('planLimitsDisplay');
            if (!limitsDisplay) return;
            const limits = details.limits || { admins: 0, bots: 1, paymentMethods: 5, groups: 1, messages: 20 };
            limitsDisplay.innerHTML = `
                <li>👥 管理员: ${limits.admins || 0}</li>
                <li>🤖 机器人: ${limits.bots || 1}</li>
                <li>💳 支付方式: ${limits.paymentMethods || 5}</li>
                <li>📢 群组: ${limits.groups || 1}</li>
                <li>📊 消息/天: ${limits.messages || 20}</li>
            `;
        }

        function showCreateForm() {
            document.getElementById('modalTitle').textContent = '创建新管理员';
            document.getElementById('adminForm').reset();
            document.getElementById('password').required = true;
            document.getElementById('password').placeholder = '至少6位字符';
            document.getElementById('adminId').value = '';
            currentEditId = null;
            
            const planSelect = document.getElementById('plan');
            if (planSelect) {
                updateAdminPlanDetails(planSelect.value);
            }
            
            document.getElementById('adminModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('adminModal').classList.remove('active');
        }

        async function editAdmin(id) {
            currentEditId = id;
            document.getElementById('modalTitle').textContent = '编辑管理员';
            document.getElementById('password').required = false;
            document.getElementById('password').placeholder = '留空则不修改密码';

            try {
                const res = await fetch(`/admin/api/admins/${id}`);
                
                if (!res.ok) {
                    const errorData = await res.json();
                    throw new Error(errorData.error || 'Failed to fetch admin');
                }
                
                const data = await res.json();

                document.getElementById('username').value = data.username || '';
                document.getElementById('role').value = data.role || 'admin';
                document.getElementById('plan').value = data.plan || 'demo';
                document.getElementById('isActive').value = data.isActive ? 'true' : 'false';
                document.getElementById('adminId').value = id;

                updateAdminPlanDetails(data.plan || 'demo');

                const adminGroupIds = [];
                if (data.accessibleGroups && Array.isArray(data.accessibleGroups)) {
                    data.accessibleGroups.forEach(function(g) {
                        if (g && g._id) {
                            adminGroupIds.push(g._id);
                        } else if (g && g.chatId) {
                            adminGroupIds.push(g.chatId);
                        } else if (g) {
                            adminGroupIds.push(g);
                        }
                    });
                }
                
                document.querySelectorAll('input[name="groups"]').forEach(function(cb) {
                    cb.checked = adminGroupIds.includes(cb.value);
                });

                document.getElementById('adminModal').classList.add('active');
            } catch (err) {
                console.error('Edit error:', err);
                alert('加载管理员数据失败: ' + err.message);
            }
        }

        document.getElementById('adminForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const username = document.getElementById('username').value.trim();
            const password = document.getElementById('password').value;
            const role = document.getElementById('role').value;
            const plan = document.getElementById('plan').value;
            const isActive = document.getElementById('isActive').value === 'true';
            const id = document.getElementById('adminId').value;

            if (!username) {
                alert('请输入用户名');
                return;
            }

            if (!id && (!password || password.length < 6)) {
                alert('创建管理员时密码至少6位字符');
                return;
            }

            const data = {
                username: username,
                role: role,
                plan: plan,
                isActive: isActive,
                accessibleGroups: Array.from(document.querySelectorAll('input[name="groups"]:checked'))
                    .map(function(cb) {
                        const label = cb.nextElementSibling;
                        return {
                            chatId: cb.value,
                            groupName: label ? label.textContent.trim() : cb.value
                        };
                    })
            };

            if (password) data.password = password;

            const url = id ? `/admin/admins/${id}` : '/admin/admins';
            const method = id ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (res.ok) {
                    const result = await res.json();
                    alert('成功: ' + (result.message || '操作成功'));
                    location.reload();
                } else {
                    const error = await res.json();
                    alert('错误: ' + (error.error || '操作失败'));
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
                console.error('Submit error:', err);
            }
        });

        async function deleteAdmin(id) {
            if (!confirm('确定要永久删除此管理员吗？')) return;

            try {
                const res = await fetch(`/admin/admins/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    const row = document.getElementById(`admin-${id}`);
                    if (row) row.remove();
                    alert('管理员删除成功！');
                } else {
                    const error = await res.json();
                    alert('错误: ' + (error.error || '删除失败'));
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
                console.error('Delete error:', err);
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('adminModal');
            if (event.target === modal) {
                closeModal();
            }
        };

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            const planSelect = document.getElementById('plan');
            if (planSelect) {
                updateAdminPlanDetails(planSelect.value);
            }
        });
    </script>
</body>
</html>
