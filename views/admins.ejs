<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>管理员管理 · 控制台</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: #f4f7fc;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .app-bar {
            background: rgba(18, 28, 46, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            color: white;
            padding: 1rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            box-shadow: 0 8px 24px rgba(0, 20, 40, 0.12);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .app-bar h1 {
            font-weight: 600;
            font-size: 1.6rem;
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .app-bar h1 i {
            color: #fbbf24;
            font-size: 1.8rem;
        }

        .app-bar div {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .btn-secondary, .btn-danger {
            padding: 0.5rem 1.2rem;
            border-radius: 60px;
            font-weight: 500;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
            border: 1px solid transparent;
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.12);
            color: #f0f4ff;
            border-color: rgba(255, 255, 255, 0.15);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.22);
            transform: translateY(-1px);
        }

        .btn-danger {
            background: rgba(239, 68, 68, 0.18);
            color: #fca5a5;
            border-color: rgba(239, 68, 68, 0.25);
        }

        .btn-danger:hover {
            background: rgba(239, 68, 68, 0.35);
            color: #fff;
        }

        .viewport-container {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 2rem;
            width: 100%;
            flex: 1;
        }

        .admin-controls {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 1.8rem;
        }

        .btn-primary {
            background: #1e3a6b;
            color: white;
            padding: 0.7rem 1.8rem;
            border-radius: 60px;
            font-weight: 600;
            border: none;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            box-shadow: 0 6px 14px rgba(26, 67, 113, 0.25);
            transition: all 0.2s;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-primary i {
            font-size: 1rem;
        }

        .btn-primary:hover {
            background: #14315a;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(18, 52, 97, 0.3);
        }

        .table-wrapper {
            background: white;
            border-radius: 28px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.04), 0 4px 12px rgba(0, 20, 40, 0.06);
            overflow-x: auto;
            padding: 0.25rem;
            backdrop-filter: blur(2px);
            border: 1px solid rgba(255, 255, 255, 0.6);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.95rem;
            min-width: 760px;
        }

        th {
            text-align: left;
            padding: 1.2rem 1rem 0.9rem 1.5rem;
            font-weight: 600;
            color: #1f2a44;
            letter-spacing: 0.02em;
            font-size: 0.8rem;
            text-transform: uppercase;
            opacity: 0.7;
            border-bottom: 1px solid #eef2f6;
        }

        td {
            padding: 1rem 1rem 1rem 1.5rem;
            border-bottom: 1px solid #f0f4fa;
            vertical-align: middle;
            color: #1a2639;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: #f8faff;
        }

        td strong {
            font-weight: 600;
            color: #0b1a33;
        }

        .badge {
            display: inline-block;
            padding: 0.25rem 0.9rem;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.01em;
            background: #eef2f6;
            color: #1f2a44;
        }

        .badge-super {
            background: #dbeafe;
            color: #1e3a8a;
        }

        .badge-admin {
            background: #e5e7eb;
            color: #374151;
        }

        .badge-plan {
            display: inline-block;
            padding: 0.2rem 0.8rem;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
        }
        .badge-demo { background: #dbeafe; color: #1e3a8a; }
        .badge-starter { background: #d1fae5; color: #065f46; }
        .badge-pro { background: #fef3c7; color: #92400e; }
        .badge-enterprise { background: #ede9fe; color: #5b21b6; }

        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.2rem 0.9rem 0.2rem 0.7rem;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 500;
        }

        .status-indicator::before {
            content: "●";
            font-size: 0.6rem;
            margin-right: 2px;
        }

        .status-indicator.active {
            background: #dcfce7;
            color: #166534;
        }

        .status-indicator.active::before {
            color: #22c55e;
        }

        .status-indicator.inactive {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-indicator.inactive::before {
            color: #ef4444;
        }

        .btn-edit, .btn-delete {
            border: none;
            background: transparent;
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.3rem 0.8rem;
            border-radius: 40px;
            transition: all 0.15s;
            cursor: pointer;
            margin: 0 2px;
        }

        .btn-edit {
            color: #2563eb;
            background: #eff6ff;
        }

        .btn-edit:hover {
            background: #dbeafe;
            color: #1e40af;
        }

        .btn-delete {
            color: #b91c1c;
            background: #fee2e2;
        }

        .btn-delete:hover {
            background: #fecaca;
            color: #7f1d1d;
        }

        .modal {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0, 10, 30, 0.5);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 999;
            padding: 1.5rem;
        }

        .modal.active {
            display: flex !important;
        }

        .modal-content {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 40px;
            max-width: 600px;
            width: 100%;
            padding: 2.2rem 2.5rem;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.6);
            transition: 0.2s;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-content h2 {
            font-weight: 600;
            font-size: 1.8rem;
            color: #0b1a33;
            margin-bottom: 1.8rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .close {
            float: right;
            font-size: 2rem;
            font-weight: 300;
            line-height: 1;
            color: #4b5563;
            cursor: pointer;
            transition: 0.2s;
            margin-top: -0.4rem;
        }

        .close:hover {
            color: #111827;
            transform: rotate(90deg);
        }

        form label {
            font-weight: 500;
            font-size: 0.85rem;
            color: #1f2a44;
            display: block;
            margin: 1rem 0 0.3rem 0;
        }

        form input, form select {
            width: 100%;
            padding: 0.7rem 1rem;
            border: 1px solid #d1d9e6;
            border-radius: 18px;
            font-size: 0.95rem;
            background: white;
            transition: 0.2s;
            outline: none;
        }

        form input:focus, form select:focus {
            border-color: #1e3a6b;
            box-shadow: 0 0 0 4px rgba(30, 58, 107, 0.12);
        }

        .plan-details {
            background: #f8fafd;
            padding: 1rem;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            margin: 0.5rem 0 0 0;
        }

        .plan-details h4 {
            margin: 0 0 0.5rem 0;
            color: #0b1a33;
        }

        .plan-details ul {
            margin: 0;
            padding-left: 1.2rem;
        }

        .plan-details ul li {
            font-size: 0.85rem;
            color: #4b5563;
            padding: 0.1rem 0;
        }

        #groupCheckboxes {
            background: #f8fafd;
            border-radius: 20px;
            padding: 1rem 1.2rem;
            margin: 0.4rem 0 0.8rem 0;
            border: 1px solid #e2e8f0;
            max-height: 160px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        #groupCheckboxes div {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        #groupCheckboxes input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #1e3a6b;
            margin: 0;
        }

        #groupCheckboxes label {
            margin: 0;
            font-weight: 400;
            font-size: 0.9rem;
            color: #1f2a44;
            cursor: pointer;
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
            color: #94a3b8;
        }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
        }

        .actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 2rem;
        }

        .actions .btn-secondary-action {
            background: #eef2f6;
            color: #1f2a44;
            border: none;
            padding: 0.6rem 1.8rem;
            border-radius: 60px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.15s;
        }

        .actions .btn-secondary-action:hover {
            background: #dce2ec;
        }

        .actions .btn-primary {
            padding: 0.6rem 2rem;
        }

        .form-hint {
            color: #64748b;
            font-size: 0.75rem;
            margin-top: 0.25rem;
            display: block;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #eef2f6;
            border-radius: 20px;
        }

        ::-webkit-scrollbar-thumb {
            background: #bac8d9;
            border-radius: 20px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #9aadc4;
        }

        @media (max-width: 650px) {
            .app-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
                padding: 1rem 1.5rem;
            }
            .viewport-container {
                padding: 0 1rem;
                margin: 1rem auto;
            }
            .modal-content {
                padding: 1.8rem;
                margin: 0.5rem;
            }
            th, td {
                padding: 0.7rem 0.5rem;
            }
        }
    </style>
</head>
<body>
    <header class="app-bar">
        <h1><i class="fas fa-user-shield"></i> 管理员控制台</h1>
        <div>
            <a href="/admin/dashboard" class="btn-secondary"><i class="fas fa-chart-pie"></i> 仪表板</a>
            <a href="/admin/logout" class="btn-danger"><i class="fas fa-sign-out-alt"></i> 退出</a>
        </div>
    </header>
    <main class="viewport-container">
        <div class="admin-controls">
            <button onclick="showCreateForm()" class="btn-primary"><i class="fas fa-user-plus"></i> 创建管理员</button>
        </div>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>用户名</th>
                        <th>角色</th>
                        <th>方案</th>
                        <th>状态</th>
                        <th>可访问群组</th>
                        <th>创建者</th>
                        <th>最后登录</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(typeof admins !== 'undefined' && admins && admins.length > 0) { %>
                        <% admins.forEach(function(admin) { %>
                            <tr id="admin-<%= admin._id %>">
                                <td><strong><%= admin.username %></strong></td>
                                <td>
                                    <span class="badge <%= admin.role === 'superadmin' ? 'badge-super' : 'badge-admin' %>">
                                        <%= admin.role === 'superadmin' ? '超级管理员' : '管理员' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge-plan badge-<%= admin.plan || 'demo' %>">
                                        <%= admin.plan ? admin.plan.toUpperCase() : 'DEMO' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="status-indicator <%= admin.isActive ? 'active' : 'inactive' %>">
                                        <%= admin.isActive ? '已启用' : '已停用' %>
                                    </span>
                                </td>
                                <td><%= admin.accessibleGroups ? admin.accessibleGroups.length : 0 %></td>
                                <td><%= admin.createdBy ? admin.createdBy.username : '系统' %></td>
                                <td><%= admin.lastLogin ? new Date(admin.lastLogin).toLocaleString('zh-CN') : '未登录' %></td>
                                <td>
                                    <button onclick="editAdmin('<%= admin._id %>')" class="btn-edit"><i class="fas fa-edit"></i> 编辑</button>
                                    <% if(admin._id.toString() !== adminData.id) { %>
                                        <button onclick="deleteAdmin('<%= admin._id %>')" class="btn-delete"><i class="fas fa-trash-alt"></i> 删除</button>
                                    <% } else { %>
                                        <span style="font-size:0.7rem; color:#94a3b8;">当前账号</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="8" class="empty-state">
                                <i class="fas fa-users"></i>
                                暂无管理员，点击 <a href="#" onclick="showCreateForm(); return false;" style="color: #2563eb;">创建管理员</a> 添加第一个管理员
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <!-- Modal -->
    <div id="adminModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal()">&times;</span>
            <h2><i class="fas fa-user-cog" style="color:#1e3a6b;"></i> <span id="modalTitle">创建管理员</span></h2>
            <form id="adminForm">
                <input type="hidden" id="adminId" name="id">
                
                <label><i class="fas fa-user"></i> 用户名 *</label>
                <input type="text" id="username" name="username" placeholder="例如: zhangsan" required>

                <label><i class="fas fa-lock"></i> 密码 <span style="font-weight:400; color:#64748b; font-size:0.8rem;">(创建时必填，编辑时留空)</span></label>
                <input type="password" id="password" name="password" placeholder="至少6位字符">

                <label><i class="fas fa-tag"></i> 角色</label>
                <select id="role" name="role">
                    <option value="admin">管理员</option>
                    <option value="superadmin">超级管理员</option>
                </select>

                <label><i class="fas fa-crown"></i> 方案</label>
                <select id="plan" name="plan">
                    <% if(typeof plans !== 'undefined' && plans && plans.length > 0) { %>
                        <% plans.forEach(function(plan) { %>
                            <option value="<%= plan.name %>">
                                <%= plan.displayName %> - <%= plan.price === 0 ? 'Free' : '$' + plan.price + '/' + plan.interval %>
                            </option>
                        <% }); %>
                    <% } else { %>
                        <option value="demo">Demo - 基础权限</option>
                        <option value="starter">Starter - 基础管理</option>
                        <option value="pro">Pro - 完整管理</option>
                        <option value="enterprise">Enterprise - 所有功能</option>
                    <% } %>
                </select>
                <span class="form-hint">选择决定该管理员权限和限制的方案</span>

                <div class="plan-details" id="adminPlanDetails">
                    <h4>📊 方案功能</h4>
                    <ul id="adminPlanFeatures" style="margin:0; padding-left:1.2rem;">
                        <li>✅ 查看分析</li>
                        <li>❌ 管理机器人</li>
                        <li>❌ 管理管理员</li>
                        <li>❌ 管理支付方式</li>
                        <li>❌ 管理群组</li>
                        <li>❌ 管理交易</li>
                    </ul>
                    <ul id="planLimitsDisplay" style="margin:0.5rem 0 0 0; padding-left:1.2rem; font-size:0.85rem; color:#4b5563;">
                        <li>👥 管理员: 0</li>
                        <li>🤖 机器人: 1</li>
                        <li>💳 支付方式: 5</li>
                        <li>📢 群组: 1</li>
                        <li>📊 消息/天: 20</li>
                    </ul>
                </div>

                <label><i class="fas fa-toggle-on"></i> 状态</label>
                <select id="isActive" name="isActive">
                    <option value="true">已启用</option>
                    <option value="false">已停用</option>
                </select>

                <label><i class="fas fa-layer-group"></i> 可访问群组</label>
                <div id="groupCheckboxes">
                    <% if(typeof groups !== 'undefined' && groups && groups.length > 0) { %>
                        <% groups.forEach(function(group) { %>
                            <div>
                                <input type="checkbox" name="groups" value="<%= group._id %>" id="group-<%= group._id %>">
                                <label for="group-<%= group._id %>"><%= group.title %> (<%= group.chatId %>)</label>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div style="color:#94a3b8; font-size:0.9rem; text-align:center; padding:0.5rem;">
                            <i class="fas fa-info-circle"></i> 暂无群组，请先创建群组
                        </div>
                    <% } %>
                </div>

                <div class="actions">
                    <button type="submit" class="btn-primary"><i class="fas fa-save"></i> 保存</button>
                    <button type="button" onclick="closeModal()" class="btn-secondary-action">取消</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Plan features mapping
        const planFeatures = {
            demo: {
                features: ['查看分析'],
                limits: { admins: 0, bots: 1, paymentMethods: 5, groups: 1, messages: 20 }
            },
            starter: {
                features: ['查看分析', '管理机器人', '管理支付方式', '管理群组', '管理交易'],
                limits: { admins: 0, bots: 2, paymentMethods: 5, groups: 2, messages: '∞' }
            },
            pro: {
                features: ['查看分析', '管理机器人', '管理支付方式', '管理群组', '管理交易', '导出数据', 'API访问'],
                limits: { admins: 0, bots: 5, paymentMethods: 7, groups: 5, messages: '∞' }
            },
            enterprise: {
                features: ['所有功能', '管理方案', '管理Webhook', '完整访问'],
                limits: { admins: 0, bots: 10, paymentMethods: '∞', groups: 10, messages: '∞' }
            }
        };

        let currentEditId = null;

        function updateAdminPlanDetails(planName) {
            if (!planName) planName = 'demo';
            const details = planFeatures[planName] || planFeatures.demo;
            const featuresList = document.getElementById('adminPlanFeatures');
            if (!featuresList) return;
            featuresList.innerHTML = '';
            
            const allFeatures = ['查看分析', '管理机器人', '管理管理员', '管理支付方式', '管理群组', '管理交易', '导出数据', 'API访问', '管理方案', '管理Webhook', '完整访问', '终身更新', '优先支持'];
            
            allFeatures.forEach(function(feature) {
                const li = document.createElement('li');
                const hasFeature = details.features && details.features.some(function(f) {
                    return feature.includes(f) || f.includes(feature);
                });
                li.innerHTML = hasFeature ? '✅ ' + feature : '❌ ' + feature;
                featuresList.appendChild(li);
            });

            const limitsDisplay = document.getElementById('planLimitsDisplay');
            if (!limitsDisplay) return;
            const limits = details.limits || { admins: 0, bots: 1, paymentMethods: 5, groups: 1, messages: 20 };
            limitsDisplay.innerHTML = `
                <li>👥 管理员: ${limits.admins || 0}</li>
                <li>🤖 机器人: ${limits.bots || 1}</li>
                <li>💳 支付方式: ${limits.paymentMethods || 5}</li>
                <li>📢 群组: ${limits.groups || 1}</li>
                <li>📊 消息/天: ${limits.messages || 20}</li>
            `;
        }

        function showCreateForm() {
            document.getElementById('modalTitle').textContent = '创建新管理员';
            document.getElementById('adminForm').reset();
            document.getElementById('password').required = true;
            document.getElementById('password').placeholder = '至少6位字符';
            document.getElementById('adminId').value = '';
            currentEditId = null;
            
            const planSelect = document.getElementById('plan');
            if (planSelect) {
                updateAdminPlanDetails(planSelect.value);
            }
            
            document.getElementById('adminModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('adminModal').classList.remove('active');
        }

        async function editAdmin(id) {
            currentEditId = id;
            document.getElementById('modalTitle').textContent = '编辑管理员';
            document.getElementById('password').required = false;
            document.getElementById('password').placeholder = '留空则不修改密码';

            try {
                const res = await fetch(`/admin/api/admins/${id}`);
                
                if (!res.ok) {
                    const errorData = await res.json();
                    throw new Error(errorData.error || 'Failed to fetch admin');
                }
                
                const data = await res.json();

                document.getElementById('username').value = data.username || '';
                document.getElementById('role').value = data.role || 'admin';
                document.getElementById('plan').value = data.plan || 'demo';
                document.getElementById('isActive').value = data.isActive ? 'true' : 'false';
                document.getElementById('adminId').value = id;

                updateAdminPlanDetails(data.plan || 'demo');

                const adminGroupIds = [];
                if (data.accessibleGroups && Array.isArray(data.accessibleGroups)) {
                    data.accessibleGroups.forEach(function(g) {
                        if (g && g._id) {
                            adminGroupIds.push(g._id);
                        } else if (g && g.chatId) {
                            adminGroupIds.push(g.chatId);
                        } else if (g) {
                            adminGroupIds.push(g);
                        }
                    });
                }
                
                document.querySelectorAll('input[name="groups"]').forEach(function(cb) {
                    cb.checked = adminGroupIds.includes(cb.value);
                });

                document.getElementById('adminModal').classList.add('active');
            } catch (err) {
                console.error('Edit error:', err);
                alert('加载管理员数据失败: ' + err.message);
            }
        }

        document.getElementById('adminForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const username = document.getElementById('username').value.trim();
            const password = document.getElementById('password').value;
            const role = document.getElementById('role').value;
            const plan = document.getElementById('plan').value;
            const isActive = document.getElementById('isActive').value === 'true';
            const id = document.getElementById('adminId').value;

            if (!username) {
                alert('请输入用户名');
                return;
            }

            if (!id && (!password || password.length < 6)) {
                alert('创建管理员时密码至少6位字符');
                return;
            }

            const data = {
                username: username,
                role: role,
                plan: plan,
                isActive: isActive,
                accessibleGroups: Array.from(document.querySelectorAll('input[name="groups"]:checked'))
                    .map(function(cb) {
                        const label = cb.nextElementSibling;
                        return {
                            chatId: cb.value,
                            groupName: label ? label.textContent.trim() : cb.value
                        };
                    })
            };

            if (password) data.password = password;

            const url = id ? `/admin/admins/${id}` : '/admin/admins';
            const method = id ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (res.ok) {
                    const result = await res.json();
                    alert('成功: ' + (result.message || '操作成功'));
                    location.reload();
                } else {
                    const error = await res.json();
                    alert('错误: ' + (error.error || '操作失败'));
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
                console.error('Submit error:', err);
            }
        });

        async function deleteAdmin(id) {
            if (!confirm('确定要永久删除此管理员吗？')) return;

            try {
                const res = await fetch(`/admin/admins/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    const row = document.getElementById(`admin-${id}`);
                    if (row) row.remove();
                    alert('管理员删除成功！');
                } else {
                    const error = await res.json();
                    alert('错误: ' + (error.error || '删除失败'));
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
                console.error('Delete error:', err);
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('adminModal');
            if (event.target === modal) {
                closeModal();
            }
        };

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            const planSelect = document.getElementById('plan');
            if (planSelect) {
                updateAdminPlanDetails(planSelect.value);
            }
        });
    </script>
</body>
</html>