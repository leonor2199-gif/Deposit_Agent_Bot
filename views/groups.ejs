<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>群组管理 · Telegram</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: #f4f7fc;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .app-bar {
            background: rgba(18, 28, 46, 0.88);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            color: white;
            padding: 0.9rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            box-shadow: 0 8px 24px rgba(0, 20, 40, 0.15);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .app-bar h1 {
            font-weight: 600;
            font-size: 1.5rem;
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .app-bar h1 i {
            color: #34d399;
        }

        .app-bar > div {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-secondary, .btn-danger {
            padding: 0.4rem 1.2rem;
            border-radius: 60px;
            font-weight: 500;
            font-size: 0.85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s ease;
            border: 1px solid transparent;
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.08);
            color: #e8edf9;
            border-color: rgba(255, 255, 255, 0.08);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.18);
            transform: translateY(-1px);
        }

        .btn-danger {
            background: rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            border-color: rgba(239, 68, 68, 0.2);
        }

        .btn-danger:hover {
            background: rgba(239, 68, 68, 0.3);
            color: #fff;
        }

        .viewport-container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 2rem;
            width: 100%;
            flex: 1;
        }

        .admin-controls {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 1.8rem;
        }

        .btn-primary {
            background: #1e3a6b;
            color: white;
            padding: 0.7rem 1.8rem;
            border-radius: 60px;
            font-weight: 600;
            border: none;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            box-shadow: 0 6px 14px rgba(26, 67, 113, 0.25);
            transition: all 0.2s;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-primary i {
            font-size: 1rem;
        }

        .btn-primary:hover {
            background: #14315a;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(18, 52, 97, 0.3);
        }

        .table-wrapper {
            background: white;
            border-radius: 28px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.03), 0 4px 12px rgba(0, 20, 40, 0.04);
            overflow-x: auto;
            padding: 0.25rem;
            border: 1px solid rgba(255, 255, 255, 0.6);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.93rem;
            min-width: 680px;
        }

        th {
            text-align: left;
            padding: 1.2rem 1rem 0.9rem 1.5rem;
            font-weight: 600;
            color: #1f2a44;
            letter-spacing: 0.02em;
            font-size: 0.75rem;
            text-transform: uppercase;
            opacity: 0.7;
            border-bottom: 1px solid #eef2f6;
        }

        td {
            padding: 1rem 1rem 1rem 1.5rem;
            border-bottom: 1px solid #f0f4fa;
            vertical-align: middle;
            color: #1a2639;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: #f8faff;
        }

        td strong {
            font-weight: 600;
            color: #0b1a33;
        }

        code {
            background: #f1f5f9;
            padding: 0.15rem 0.7rem;
            border-radius: 30px;
            font-size: 0.8rem;
            color: #1e293b;
            font-family: 'Menlo', 'Monaco', monospace;
        }

        .badge {
            display: inline-block;
            padding: 0.2rem 0.9rem;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.01em;
            text-transform: uppercase;
        }

        .badge-customer {
            background: #dbeafe;
            color: #1e3a8a;
        }

        .badge-merchant {
            background: #fef3c7;
            color: #92400e;
        }

        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.2rem 0.9rem 0.2rem 0.7rem;
            border-radius: 40px;
            font-size: 0.78rem;
            font-weight: 500;
        }

        .status-indicator::before {
            content: "●";
            font-size: 0.6rem;
            margin-right: 2px;
        }

        .status-indicator.active {
            background: #dcfce7;
            color: #166534;
        }
        .status-indicator.active::before { color: #22c55e; }

        .status-indicator.inactive {
            background: #fee2e2;
            color: #991b1b;
        }
        .status-indicator.inactive::before { color: #ef4444; }

        .btn-edit, .btn-delete {
            border: none;
            background: transparent;
            font-size: 0.8rem;
            font-weight: 500;
            padding: 0.3rem 0.9rem;
            border-radius: 40px;
            transition: all 0.15s;
            cursor: pointer;
        }

        .btn-edit {
            color: #2563eb;
            background: #eff6ff;
        }
        .btn-edit:hover {
            background: #dbeafe;
            color: #1e40af;
        }

        .btn-delete {
            color: #b91c1c;
            background: #fee2e2;
        }
        .btn-delete:hover {
            background: #fecaca;
            color: #7f1d1d;
        }

        .modal {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0, 10, 30, 0.5);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 999;
            padding: 1.5rem;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 40px;
            max-width: 520px;
            width: 100%;
            padding: 2.2rem 2.5rem;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.5);
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-content h2 {
            font-weight: 600;
            font-size: 1.7rem;
            color: #0b1a33;
            margin-bottom: 1.8rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-content h2 i {
            color: #1e3a6b;
        }

        .close {
            float: right;
            font-size: 2rem;
            font-weight: 300;
            line-height: 1;
            color: #4b5563;
            cursor: pointer;
            transition: 0.2s;
            margin-top: -0.4rem;
        }

        .close:hover {
            color: #111827;
            transform: rotate(90deg);
        }

        form label {
            font-weight: 500;
            font-size: 0.85rem;
            color: #1f2a44;
            display: block;
            margin: 1rem 0 0.3rem 0;
        }

        form input, form select {
            width: 100%;
            padding: 0.7rem 1rem;
            border: 1px solid #d1d9e6;
            border-radius: 18px;
            font-size: 0.95rem;
            background: white;
            transition: 0.2s;
            outline: none;
        }

        form input:focus, form select:focus {
            border-color: #1e3a6b;
            box-shadow: 0 0 0 4px rgba(30, 58, 107, 0.08);
        }

        .actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 2rem;
        }

        .actions .btn-secondary {
            background: #eef2f6;
            color: #1f2a44;
            border: none;
            padding: 0.6rem 1.8rem;
            border-radius: 60px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.15s;
        }

        .actions .btn-secondary:hover {
            background: #dce2ec;
        }

        .actions .btn-primary {
            padding: 0.6rem 2rem;
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
            color: #94a3b8;
        }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
        }

        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #eef2f6; border-radius: 20px; }
        ::-webkit-scrollbar-thumb { background: #bac8d9; border-radius: 20px; }
        ::-webkit-scrollbar-thumb:hover { background: #9aadc4; }

        @media (max-width: 650px) {
            .app-bar { flex-direction: column; align-items: stretch; padding: 0.8rem 1.2rem; }
            .app-bar > div { justify-content: flex-start; }
            .viewport-container { padding: 0 1rem; margin: 1rem auto; }
            .modal-content { padding: 1.8rem 1.2rem; }
            .admin-controls { justify-content: center; }
        }
    </style>
</head>
<body>
    <header class="app-bar">
        <h1><i class="fas fa-telegram-plane"></i> Telegram 群组管理</h1>
        <div>
            <a href="/admin/dashboard" class="btn-secondary"><i class="fas fa-chart-pie"></i> 返回仪表板</a>
            <a href="/admin/logout" class="btn-danger"><i class="fas fa-sign-out-alt"></i> 退出登录</a>
        </div>
    </header>

    <main class="viewport-container">
        <div class="admin-controls">
            <button onclick="showCreateForm()" class="btn-primary"><i class="fas fa-plus-circle"></i> 添加群组</button>
        </div>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>群组名称</th>
                        <th>群组 ID</th>
                        <th>类型</th>
                        <th>状态</th>
                        <th>管理员数</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(groups && groups.length > 0) { %>
                        <% groups.forEach(group => { %>
                            <tr id="group-<%= group._id %>">
                                <td><strong><%= group.title %></strong></td>
                                <td><code><%= group.chatId %></code></td>
                                <td>
                                    <span class="badge <%= group.type === 'customer_facing' ? 'badge-customer' : 'badge-merchant' %>">
                                        <%= group.type === 'customer_facing' ? '客户群' : '商户后台' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="status-indicator <%= group.isActive ? 'active' : 'inactive' %>">
                                        <%= group.isActive ? '已启用' : '已停用' %>
                                    </span>
                                </td>
                                <td><%= group.accessibleBy ? group.accessibleBy.length : 0 %></td>
                                <td>
                                    <button onclick="editGroup('<%= group._id %>')" class="btn-edit"><i class="fas fa-edit"></i> 编辑</button>
                                    <button onclick="deleteGroup('<%= group._id %>')" class="btn-delete"><i class="fas fa-trash-alt"></i> 删除</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" class="empty-state">
                                <i class="fas fa-inbox"></i>
                                暂无群组，点击 <a href="#" onclick="showCreateForm(); return false;" style="color: #2563eb;">添加群组</a> 创建第一个群组
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <!-- Modal -->
    <div id="groupModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeModal()">&times;</span>
            <h2><i class="fas fa-users-cog"></i> <span id="modalTitle">添加群组</span></h2>
            <form id="groupForm">
                <input type="hidden" id="groupId" name="id">

                <label><i class="fas fa-tag"></i> 群组名称 *</label>
                <input type="text" id="title" name="title" placeholder="例如: 全球客户支持" required>

                <label><i class="fas fa-hashtag"></i> 群组 ID (Chat ID) *</label>
                <input type="text" id="chatId" name="chatId" placeholder="-1001234567890" required>

                <label><i class="fas fa-layer-group"></i> 群组类型 *</label>
                <select id="type" name="type" required>
                    <option value="customer_facing">客户群</option>
                    <option value="merchant_backoffice">商户后台</option>
                </select>

                <label><i class="fas fa-toggle-on"></i> 状态</label>
                <select id="isActive" name="isActive">
                    <option value="true">已启用</option>
                    <option value="false">已停用</option>
                </select>

                <div class="actions">
                    <button type="submit" class="btn-primary"><i class="fas fa-save"></i> 保存</button>
                    <button type="button" onclick="closeModal()" class="btn-secondary">取消</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function showCreateForm() {
            document.getElementById('modalTitle').textContent = '添加新群组';
            document.getElementById('groupForm').reset();
            document.getElementById('groupId').value = '';
            document.getElementById('groupModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('groupModal').classList.remove('active');
        }

        async function editGroup(id) {
            document.getElementById('modalTitle').textContent = '编辑群组';
            document.getElementById('groupId').value = id;

            try {
                const res = await fetch(`/admin/api/groups/${id}`);
                if (!res.ok) throw new Error('Failed to fetch group');
                const data = await res.json();
                
                document.getElementById('title').value = data.title;
                document.getElementById('chatId').value = data.chatId;
                document.getElementById('type').value = data.type;
                document.getElementById('isActive').value = data.isActive ? 'true' : 'false';
                
                document.getElementById('groupModal').classList.add('active');
            } catch (err) {
                alert('加载群组数据失败: ' + err.message);
            }
        }

        document.getElementById('groupForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const id = document.getElementById('groupId').value;
            const data = {
                title: document.getElementById('title').value.trim(),
                chatId: document.getElementById('chatId').value.trim(),
                type: document.getElementById('type').value,
                isActive: document.getElementById('isActive').value === 'true'
            };

            // Validate
            if (!data.title || !data.chatId) {
                alert('请填写所有必填字段');
                return;
            }

            const url = id ? `/admin/groups/${id}` : '/admin/groups';
            const method = id ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (res.ok) {
                    location.reload();
                } else {
                    const error = await res.json();
                    alert('错误: ' + (error.error || '操作失败'));
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
            }
        });

        async function deleteGroup(id) {
            if (!confirm('确定要永久删除此群组吗？')) return;
            
            try {
                const res = await fetch(`/admin/groups/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    const row = document.getElementById(`group-${id}`);
                    if (row) row.remove();
                } else {
                    const error = await res.json();
                    alert('错误: ' + (error.error || '删除失败'));
                }
            } catch (err) {
                alert('请求失败: ' + err.message);
            }
        }

        // Close modal on outside click
        window.onclick = function(event) {
            const modal = document.getElementById('groupModal');
            if (event.target === modal) closeModal();
        }

        // Close modal on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });
    </script>
</body>
</html>