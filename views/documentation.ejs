            font-size: 0.9rem;
        }
        
        .docs-content pre {
            background: rgba(255,255,255,0.05);
            padding: 1.5rem;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.05);
            overflow-x: auto;
            margin: 1rem 0;
        }
        
        .docs-content pre code {
            background: transparent;
            color: #e2e8f0;
            font-size: 0.85rem;
        }
        
        .docs-content .step {
            background: rgba(255,255,255,0.03);
